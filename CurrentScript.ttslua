__bundle_register("engine.tools.measure", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- engine/measure.ttslua
-- Misurazione distanza tra oggetti selezionati
-- ============================================================

ENGINE_MEASURE = {
    LINE_DURATION  = 8,
    LINE_COLOR     = {0, 0, 0},
    LINE_THICKNESS = 0.08,
    SCALE          = 1.2652,
    UNIT_LABEL     = "cm",
    activeLine     = nil,
}

-- ============================================================
-- FUNZIONE: engine_measure(player)
-- ============================================================
function engine_measure(player, value, id, buttonConfig)

    local selected = lionheart_getSelectedObjects(player)

    if not selected or #selected < 2 then
        fadeOut("To measure the distance, select two items", "White", player)
        return false
    end

    local objA = selected[1]
    local objB = selected[2]

    local posA = objA.getPosition()
    local posB = objB.getPosition()

    local infoA = deployment_parseNickname(objA.getName())
    local infoB = deployment_parseNickname(objB.getName())

    local tipoA = infoA and infoA.unitType or ""
    local tipoB = infoB and infoB.unitType or ""

    local boundsA = objA.getBounds()
    local boundsB = objB.getBounds()

    local dirAB = (Vector(posB.x, posB.y, posB.z) - Vector(posA.x, posA.y, posA.z)):normalized()

    local offsetA = math.abs(boundsA.size.x/2 * dirAB.x) + math.abs(boundsA.size.z/2 * dirAB.z)
    local offsetB = math.abs(boundsB.size.x/2 * dirAB.x) + math.abs(boundsB.size.z/2 * dirAB.z)

    local dirAB = (Vector(posB.x, posB.y, posB.z) - Vector(posA.x, posA.y, posA.z)):normalized()

    local startPoint = Vector(posA.x + dirAB.x * offsetA, posA.y + 0.1, posA.z + dirAB.z * offsetA)
    local endPoint   = Vector(posB.x - dirAB.x * offsetB, posB.y + 0.1, posB.z - dirAB.z * offsetB)

    local dist = (endPoint - startPoint):magnitude() * ENGINE_MEASURE.SCALE
    local msg = string.format("The distance between your unit %s and %s is of %.1f %s", objA.getName(), objB.getName(), dist, ENGINE_MEASURE.UNIT_LABEL)
    warningToColor(msg, "Orange", player)

    ENGINE_MEASURE.activeLine = {
        points    = {startPoint, endPoint},
        color     = ENGINE_MEASURE.LINE_COLOR,
        thickness = ENGINE_MEASURE.LINE_THICKNESS,
    }

    callHandler("aggiornaLinee")

    Wait.time(function()
        ENGINE_MEASURE.activeLine = nil
        callHandler("aggiornaLinee")
    end, ENGINE_MEASURE.LINE_DURATION)

    return true
end
end)
__bundle_register("engine.tools.dice", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- engine/dice.ttslua
-- Gestione dadi virtuale/fisico
-- ============================================================

-- ============================================================
-- FUNZIONE: engine_rollDice(numDadi, soglia, callback)
-- Tira N dadi D6 e restituisce quanti >= soglia
-- callback(hits, results) dove results è la lista dei valori
-- ============================================================
function engine_rollDice(numDadi, soglia, callback)

    if numDadi <= 0 then
        if callback then callback(0, {}) end
        return
    end

    local results = {}
    local hits    = 0

    for i = 1, numDadi do
        local val = math.random(1, 6)
        table.insert(results, val)
        if val >= soglia then
            hits = hits + 1
        end
    end

    -- Simula animazione con spinDie
    local resultStr = table.concat(results, " | ")
    printToAll("[DICE] " .. numDadi .. "D6 (soglia " .. soglia .. "+): " .. resultStr .. " → HIT: " .. hits, {r=1,g=0.85,b=0.2})

    if callback then callback(hits, results) end
end

-- ============================================================
-- FUNZIONE: engine_rollDiceAnimated(numDadi, soglia, imageId, callback)
-- Come engine_rollDice ma con animazione spinDie su un elemento UI
-- ============================================================
function engine_rollDiceAnimated(numDadi, soglia, imageId, callback)

    if numDadi <= 0 then
        if callback then callback(0, {}) end
        return
    end

    local results  = {}
    local hits     = 0
    local pending  = numDadi
    local complete = false

    local function checkDone()
        if complete then return end
        pending = pending - 1
        if pending <= 0 then
            complete = true
            local resultStr = table.concat(results, " | ")
            printToAll("[DICE] " .. numDadi .. "D6 (soglia " .. soglia .. "+): " .. resultStr .. " → HIT: " .. hits, {r=1,g=0.85,b=0.2})
            if callback then callback(hits, results) end
        end
    end

    for i = 1, numDadi do
        local idx = i
        spinDie(imageId or "diceArmy1", i, function(val)
            results[idx] = val
            if val >= soglia then hits = hits + 1 end
            checkDone()
        end)
        Wait.time(function() end, i * 0.1) -- piccolo offset per non sovrapporre
    end
end

end)
