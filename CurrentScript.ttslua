    if not decoded then
        print("JSON decode FALLITO")
        return
    end

    local phasesData = decoded[1] or decoded
    
    if not ENGINE then
        ENGINE = {
            phase = "SITTING",
            turn = 1,
            phases = phasesData
        }
    else
        ENGINE.phases = phasesData
    
        if not ENGINE.phase then
            ENGINE.phase = "SITTING"
        end
    
        if not ENGINE.turn then
            ENGINE.turn = 1
        end
    end

    if not TURN then
        TURN = {
            phase = ENGINE.phase,
            activeArmy = nil,
            firstArmy = nil,
            completed = {
                Army1 = false,
                Army2 = false
            }
        }
    end
end
