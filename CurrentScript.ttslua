-- ============================================================
-- FUNZIONE: mostraPopupUnita()
-- ============================================================
function mostraPopupUnita(obj, player)

    if obj == nil then return end
    local slot = nil
    if obj.hasTag("Army1") then slot = 1 end
    if obj.hasTag("Army2") then slot = 2 end
    if slot == nil then return end

    local nickname = obj.getName()
    local baseInfo = deployment_parseNickname(nickname)
    if not baseInfo then return end

    local unita = nil
    local esercito = DEPLOYMENT.scanned[slot]

    if not esercito or #esercito == 0 then
        callHandler("deployment_scanTable")
        esercito = DEPLOYMENT.scanned[slot]
    end

    if esercito then
        for _, u in ipairs(esercito) do
            if u.tipo == baseInfo.unitType and u.unita_num == baseInfo.unitNumber then
                unita = u
                break
            end
        end
    end
    if not unita then return end

    local p      = "unit_popup_" .. slot
    local tipo   = unita.tipo
    local arma   = unita.arma
    local rules  = LIONHEART_RULES and LIONHEART_RULES.units[tipo]

    local fpb    = (LIONHEART_DATA.unitTypes[tipo] or {}).fpb or 1
    local fig_att  = lionheart_figureTotaliUnita(unita)
    local fig_max  = (unita.basi_max or #unita.basi) * fpb
    local basi_p   = lionheart_basiPresentiUnita(unita)
    local basi_max = unita.basi_max or #unita.basi
    local perc     = fig_max > 0 and (fig_att / fig_max) or 0
    
    local salute
    if perc == 1.0   then salute = "Healthy"
    elseif perc > 0.5 then salute = "Weakened"
    elseif perc > 0   then salute = "Critical"
    else                   salute = "Destroyed" end

    local army_name = (DEPLOYMENT.armies and DEPLOYMENT.armies[slot] and DEPLOYMENT.armies[slot].displayName) or ("Army " .. slot)
    local val_str   = (unita.valore == "S" or unita.valore == 1)  and "Superior" or
                      (unita.valore == "I" or unita.valore == -1) and "Inferior"  or "Normal"
    local unit_name = rules and rules.name or tipo
    local army_tag  = "Army" .. tostring(slot)

    -- HEADER
    UI.setAttribute(p .. "_icon",     "image", army_tag .. "_" .. tipo)
    UI.setAttribute(p .. "_title",    "text",  unit_name:upper())
    UI.setAttribute(p .. "_subtitle", "text",  tipo .. "  ·  " .. army_name .. "  ·  " .. val_str)
    UI.setAttribute(p .. "_basi",     "text",  "Bases:  " .. basi_p  .. " / " .. basi_max)
    UI.setAttribute(p .. "_figure",   "text",  "Figs:   " .. fig_att .. " / " .. fig_max)
    UI.setAttribute(p .. "_salute",   "text",  "Status: " .. salute)
    if not arma then 
        UI.setAttribute(p .. "_weapon", "active", "false")
    else 
        UI.setAttribute(p .. "_weapon", "active", "true")
    end


    -- MOVIMENTO
    if rules then
        local m = rules.mov
        UI.setAttribute(p .. "_mov_open",  "text", tostring(m.open))
        UI.setAttribute(p .. "_mov_wood",  "text", tostring(m.wood))
        UI.setAttribute(p .. "_mov_rough", "text", tostring(m.rough))
        UI.setAttribute(p .. "_mov_ford",  "text", tostring(m.ford))
        UI.setAttribute(p .. "_mov_pivot", "text", tostring(m.pivot))
    else
        for _, id in ipairs({"open","wood","rough","ford","pivot"}) do
            UI.setAttribute(p .. "_mov_" .. id, "text", "—")
        end
    end

    -- MELEE
    local melee = LIONHEART_RULES and LIONHEART_RULES.melee[tipo]
    if melee then
        UI.setAttribute(p .. "_mel_ai",  "text", melee.AI  .. (tonumber(melee.AI)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_mel_ui",  "text", melee.UI  .. (tonumber(melee.UI)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_mel_sk",  "text", melee.SK  .. (tonumber(melee.SK)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_mel_ac",  "text", melee.AC  .. (tonumber(melee.AC)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_mel_uc",  "text", melee.UC  .. (tonumber(melee.UC)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_mel_skc", "text", melee.SKC .. (tonumber(melee.SKC) == 6 and "" or "+"))
    else
        for _, id in ipairs({"ai","ui","sk","ac","uc","skc"}) do
            UI.setAttribute(p .. "_mel_" .. id, "text", "—")
        end
    end

    -- SHOOTING
    if arma and LIONHEART_RULES and LIONHEART_RULES.weapons[arma] then
        local w   = LIONHEART_RULES.weapons[arma]
        local mth = w.min_to_hit
        UI.setAttribute(p .. "_shoot_label", "text", "SHOOTING")
        UI.setAttribute(p .. "_weapon", "text", "Weapon: " .. w.name .. "    Range: " .. w.range)
        UI.setAttribute(p .. "_sho_ai",  "text", mth.AI  .. (tonumber(mth.AI)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_sho_ui",  "text", mth.UI  .. (tonumber(mth.UI)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_sho_sk",  "text", mth.SK  .. (tonumber(mth.SK)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_sho_ac",  "text", mth.AC  .. (tonumber(mth.AC)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_sho_uc",  "text", mth.UC  .. (tonumber(mth.UC)  == 6 and "" or "+"))
        UI.setAttribute(p .. "_sho_skc", "text", mth.SKC .. (tonumber(mth.SKC) == 6 and "" or "+"))
    else
        UI.setAttribute(p .. "_shoot_label", "text", "SHOOTING")
        for _, id in ipairs({"ai","ui","sk","ac","uc","skc"}) do
            UI.setAttribute(p .. "_sho_" .. id, "text", "—")
        end
    end

    -- SPECIAL RULES
    if rules and rules.special and #rules.special > 0 then
        local txt = ""
        for _, s in ipairs(rules.special) do
            txt = txt .. s .. "\n"
        end
        UI.setAttribute(p .. "_special", "text", txt:gsub("\n$", ""))
    else
        UI.setAttribute(p .. "_special", "text", "—")
    end

    UI.setAttribute(p, "active",     "true")
    UI.setAttribute(p, "visibility", player.color)
end

-- ============================================================
-- FUNZIONE: onUnitPopupClose
-- ============================================================
function onUnitPopupClose(player, value, id)
    local slot = getArmyByColor(player)
    if slot then
        UI.setAttribute("unit_popup_" .. slot, "active", "false")
    end
end

-- ============================================================
-- FUNZIONE: lionheart_basiPresentiUnita(unita)
-- ============================================================
function lionheart_basiPresentiUnita(unita)
    local count = 0
    for _, base in ipairs(unita.basi) do
        local obj = getObjectFromGUID(base.guid)
        if obj then count = count + 1 end
    end
    return count
end

-- ============================================================
-- FUNZIONE: lionheart_figureTotaliUnita(unita)
-- ============================================================
function lionheart_figureTotaliUnita(unita)
    local fpb    = (LIONHEART_DATA.unitTypes[unita.tipo] or {}).fpb or 0
    local figure = 0
    for _, base in ipairs(unita.basi) do
        local wounds = wounds_data and wounds_data[base.nickname] or 0
        figure = figure + math.max(0, fpb - wounds)
    end
    return figure
end
-- ============================================================
-- FUNZIONE: aggiornaSchedeUnita() — compatibilità
-- ============================================================
function aggiornaSchedeUnita()
end

end)
__bundle_register("rulesets.lionheart.engine.persistence", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- FUNZIONE: lionheart_save()
-- ============================================================
function lionheart_save()
    return lionheart_onSave()
end

-- ============================================================
-- FUNZIONE: lionheart_onSave()
-- ============================================================
function lionheart_onSave()

    local players_saved = {}

    local p1 = Player[COLOR.ARMY1]
    if p1 and p1.seated then
        players_saved[1] = {
            steam_id   = p1.steam_id,
            steam_name = p1.steam_name,
            color      = COLOR.ARMY1,
            slot       = 1,
            seated     = p1.seated
        }
    end

    local p2 = Player[COLOR.ARMY2]
    if p2 and p2.seated then
        players_saved[2] = {
            steam_id   = p2.steam_id,
            steam_name = p2.steam_name,
            color      = COLOR.ARMY2,
            slot       = 2,
            seated     = p2.seated
        }
    end

    local saveData = {
        engine = {
            phase = ENGINE and ENGINE.phase or nil,
            turn  = ENGINE and ENGINE.turn or nil
        },
        players_saved = players_saved,
        dice_contest = DICE_CONTEST,
        turn         = TURN,
        colorArmy1 = colorArmy1,
        colorArmy2 = colorArmy2,
        wounds_data   = wounds_data,
        deployment_armies = DEPLOYMENT and DEPLOYMENT.armies or nil,
        unitTypes         = LIONHEART_DATA.unitTypes
    }

    return JSON.encode(saveData)
end

-- ============================================================
-- FUNZIONE: manual_save()
-- ============================================================
function manual_save()
    local data = lionheart_onSave()
    restoreState(data)
    return data
end

-- ============================================================
-- FUNZIONE: restoreState()
-- ============================================================
function restoreState(save_state)

    if not save_state or save_state == "" then
        return false
    end

    local ok, data = pcall(JSON.decode, save_state)

    if not ok or not data then
        print("restoreState: JSON decode fallito")
        return false
    end

    ENGINE = ENGINE or {}

    if data.engine then
        ENGINE.phase = data.engine.phase or ENGINE.phase
        ENGINE.turn  = data.engine.turn or ENGINE.turn
    end

    players_saved = data.players_saved or {}

    if data.turn then
        TURN = data.turn
    end

    if data.dice_contest then
        DICE_CONTEST = data.dice_contest
    end

    colorArmy1 = data.colorArmy1 or COLOR.NOARMY
    colorArmy2 = data.colorArmy2 or COLOR.NOARMY

    if data.wounds_data then
        wounds_data = data.wounds_data
    end

    if data.deployment_armies then
        DEPLOYMENT = DEPLOYMENT or {}
        DEPLOYMENT.armies = data.deployment_armies
    end

    if data.unitTypes then
        LIONHEART_DATA.unitTypes = data.unitTypes
    end

    Wait.time(function()
        callHandler("deployment_scanTable")
        callHandler("aggiornaSchedeUnita")
    end, 2)

    return true
end

-- ============================================================
-- FUNZIONE: restorePlayersColors()
-- ============================================================
function restorePlayersColors()

    if not players_saved then return end

    local currentPlayers = Player.getPlayers()

    for _, saved in pairs(players_saved) do
        for _, p in ipairs(currentPlayers) do
            if tostring(p.steam_id) == tostring(saved.steam_id) then
                p.changeColor(saved.color)
            end
        end
    end
end

-- ============================================================
-- FUNZIONE: restoreDiceUiState()
-- ============================================================
function restoreDiceUiState()

    if not DICE_CONTEST or not diceUrls then return end

    local resetUrl = diceUrls[1]

    if DICE_CONTEST.rolledNumberArmy1 then
        UI.setAttribute("diceArmy1", "image", diceUrls[DICE_CONTEST.rolledNumberArmy1])
    else
        UI.setAttribute("diceArmy1", "image", resetUrl)
    end

    if DICE_CONTEST.rolledNumberArmy2 then
        UI.setAttribute("diceArmy2", "image", diceUrls[DICE_CONTEST.rolledNumberArmy2])
    else
        UI.setAttribute("diceArmy2", "image", resetUrl)
    end
end
end)
__bundle_register("rulesets.lionheart.engine.lib", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- FUNZIONE: lionheart_loadButtonBar()
-- ============================================================
function lionheart_loadButtonBar(callback)

    WebRequest.get(LIONHEART_BUTTONBAR_URL, function(request)
        if request.is_error then
            printToAll("[LIONHEART] Errore download buttonbar.json", {r=1,g=0.3,b=0.3})

            if callback then callback(false) end
            return
        end

        if DEBUG then print("lionheart_loadButtonBar") end
        local ok = callHandler("engine_buttonBarLoadJson", request.text)
        if callback then callback(ok) end

    end)
end
-- ============================================================
-- FUNZIONE: restart()
-- ============================================================
function restart()

    initPhases()

    ENGINE = ENGINE or {}
    ENGINE.handlers = ENGINE.handlers or {}
    ENGINE.conditions = ENGINE.conditions or {}

    ENGINE.phase = "SITTING"
    ENGINE.turn = 1
 
    colorArmy1 = COLOR.NOARMY
    colorArmy2 = COLOR.NOARMY
     
    DICE_CONTEST = {
        rolledNumberArmy1 = nil,
        rolledNumberArmy2 = nil,
        winner = nil,
        initiative = nil
    }
    
    TURN = {
        phase = "SITTING",
        activeArmy = nil,
        firstArmy = nil,
        completed = {
            Army1 = false,
            Army2 = false
        }
    }

    UI.setAttribute("iconWinnerArmy1", "active", "false")
    UI.setAttribute("iconWinnerArmy2", "active", "false")

    UI.setAttribute("iconMoveArmy1", "active", "false")
    UI.setAttribute("iconMoveArmy2", "active", "false")

    -- Rimuovi elementi terreno spawnati
for _, obj in ipairs(getAllObjects()) do
    if obj.hasTag and (obj.hasTag("Hill") or obj.hasTag("Field") or obj.hasTag("Wood")) then
        obj.destruct()
    end
end

    callHandler("initUI")
    callHandler("resetPlayers")
    callHandler("restoreDiceUiState")
    callHandler("updateCenterPanel")
    callHandler("aggiornaLinee")
    callHandler("deployment_resetRuntimeOnly")
    callHandler("deployment_clearSpawnedModels")
    fadeOut("RESTART", nil)
end
-- ============================================================
-- FUNZIONE: getArmySlotByColor()
-- ============================================================
function getArmySlotByColor(color)
    if color == COLOR.ARMY1 then return "Army1" end
    if color == COLOR.ARMY2 then return "Army2" end
    return nil
end
-- ============================================================
-- FUNZIONE: getColorByArmySlot()
-- ============================================================
function getColorByArmySlot(armySlot)
    if armySlot == "Army1" then return COLOR.ARMY1 end
    if armySlot == "Army2" then return COLOR.ARMY2 end
    return nil
end
-- ============================================================
-- FUNZIONE: blinkObject()
-- ============================================================
function blinkObject(id)
    local visible = true

    Wait.time(function()
        visible = not visible
        UI.setAttribute(id, "active", visible and "true" or "false")
    end, 0.4, -1) 
end
-- ============================================================
-- FUNZIONE: resetPlayers()
-- ============================================================
function resetPlayers()

    for _, p in ipairs(Player.getPlayers()) do
        if p then
        p.changeColor(COLOR.NOARMY)
        end
    end
end
-- ============================================================
-- FUNZIONE: countSeated()
-- ============================================================
function countSeated()
    numeroPlayerSeated = 0
    for _, p in ipairs(Player.getPlayers()) do
        if p and p.seated then
            if p and p.seated then
                if p.color == "Green" then numeroPlayerSeated=numeroPlayerSeated+1 end
                if p.color == "Red" then numeroPlayerSeated=numeroPlayerSeated+1 end                
            end
        end
    end
    return numeroPlayerSeated
end
-- ============================================================
-- FUNZIONE: isOtherPlayerSeated()
-- ============================================================
function isOtherPlayerSeated(player)

    local function checkPlayer(player)
        if player.color ~= COLOR.NOARMY then 
            return true
        end    
    end    

    for _, p in ipairs(Player.getPlayers()) do
        if p and p.seated then
            if p.steam_name ~= player.steam_name then
                return checkPlayer(p)
            end
        end
    end
    return false
end
-- ============================================================
-- FUNZIONE: isArmy1Seated()
-- ============================================================
function isArmy1Seated()
    for _, p in ipairs(Player.getPlayers()) do
        if p and p.seated then
            if p.color == COLOR.ARMY1 then 
                return true
            end
        end
    end
end
-- ============================================================
-- FUNZIONE: isArmy2Seated()
-- ============================================================
function isArmy2Seated()
    for _, p in ipairs(Player.getPlayers()) do
        if p and p.seated then
            if p.color == COLOR.ARMY2 then 
                return true
            end
        end
    end
end
-- ============================================================
-- FUNZIONE: onPlayerConnect()
-- ============================================================
function onPlayerConnect(player)
    if DEBUG then print("onPlayerConnect") end
    fadeOut(player.steam_name .." joined the game", nil)
    print(player.color .." joined the game")
    restorePlayersColors()
end
-- ============================================================
-- FUNZIONE: onPlayerDisconnect()
-- ============================================================
function onPlayerDisconnect(player)
    if DEBUG then print("onPlayerDisconnect") end
    fadeOut(player.steam_name .." left the game", nil)
end
--=============================================================
--FUNZIONE: onPlayerChangeColor()
--=============================================================
function onPlayerChangeColor(color)

    if not color then return end
    if color == COLOR.GM or color == COLOR.NOARMY then 

            if not isArmy1Seated() then
                colorArmy1 = COLOR.NOARMY
            end

            if not isArmy2Seated() then
                colorArmy2 = COLOR.NOARMY
            end        
    end

    if COLOR.ARMY1 == color then colorArmy1 = color end
    if COLOR.ARMY2 == color then colorArmy2 = color end

    callHandler("updateCenterPanel")
end
--=============================================================
--FUNZIONE: getArmyByButton()
--=============================================================
function getArmyByButton(id)
    for k,v in pairs(ARMY) do
        if v.button == id then
            return k
        end
    end
    return nil
end
--=============================================================
--FUNZIONE: getArmyByColor()
--=============================================================
function getArmyByColor(player)

    for k,v in pairs(ARMY) do
        if v.color == player.color then
            return k
        end
    end
    return nil
end
