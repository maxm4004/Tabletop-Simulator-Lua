    activeTarget = nil,
    activeAnimation = nil,
    range = 60,
    angle = 45
}

LIONHEART_SHOOT_STATE = {
    shooter     = nil,   -- oggetto tiratore
    target      = nil,   -- oggetto bersaglio
    shooterUnit = nil,   -- dati unità tiratore
    targetUnit  = nil,   -- dati unità bersaglio
    shooterSlot = nil,   -- slot army tiratore
    targetSlot  = nil,   -- slot army bersaglio
}

LIONHEART_FIRED = LIONHEART_FIRED or {}
end)
