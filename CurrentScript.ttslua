__bundle_register("rulesets.lionheart.persistence", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- FUNZIONE: lionheart_save()
-- ============================================================
function lionheart_save()
    return lionheart_onSave()
end

-- ============================================================
-- FUNZIONE: lionheart_onSave()
-- ============================================================
function lionheart_onSave()

    local players_saved = {}

    local p1 = Player[COLOR.ARMY1]
    if p1 and p1.seated then
        players_saved[1] = {
            steam_id   = p1.steam_id,
            steam_name = p1.steam_name,
            color      = COLOR.ARMY1,
            slot       = 1,
            seated     = p1.seated
        }
    end

    local p2 = Player[COLOR.ARMY2]
    if p2 and p2.seated then
        players_saved[2] = {
            steam_id   = p2.steam_id,
            steam_name = p2.steam_name,
            color      = COLOR.ARMY2,
            slot       = 2,
            seated     = p2.seated
        }
    end

    local saveData = {
        engine = {
            phase = ENGINE and ENGINE.phase or nil,
            turn  = ENGINE and ENGINE.turn or nil
        },
        players_saved = players_saved,
        dice_contest = DICE_CONTEST,
        turn         = TURN,
        colorArmy1 = colorArmy1,
        colorArmy2 = colorArmy2,
        wounds_data   = wounds_data,
    }

    return JSON.encode(saveData)
end

-- ============================================================
-- FUNZIONE: manual_save()
-- ============================================================
function manual_save()
    local data = lionheart_onSave()
    restoreState(data)
    return data
end

-- ============================================================
-- FUNZIONE: restoreState()
-- ============================================================
function restoreState(save_state)

    if not save_state or save_state == "" then
        return false
    end

    local ok, data = pcall(JSON.decode, save_state)

    if not ok or not data then
        print("restoreState: JSON decode fallito")
        return false
    end

    ENGINE = ENGINE or {}

    if data.engine then
        ENGINE.phase = data.engine.phase or ENGINE.phase
        ENGINE.turn  = data.engine.turn or ENGINE.turn
    end

    players_saved = data.players_saved or {}

    if data.turn then
        TURN = data.turn
    end

    if data.dice_contest then
        DICE_CONTEST = data.dice_contest
    end

    colorArmy1 = data.colorArmy1 or COLOR.NOARMY
    colorArmy2 = data.colorArmy2 or COLOR.NOARMY

    if data.wounds_data then
        wounds_data = data.wounds_data
    end

    Wait.time(function()
        deployment_scanTable()
        callHandler("aggiornaSchedeUnita")
    end, 2)

    return true
end

-- ============================================================
-- FUNZIONE: restorePlayersColors()
-- ============================================================
function restorePlayersColors()

    if not players_saved then return end

    local currentPlayers = Player.getPlayers()

    for _, saved in pairs(players_saved) do
        for _, p in ipairs(currentPlayers) do
            if tostring(p.steam_id) == tostring(saved.steam_id) then
                p.changeColor(saved.color)
            end
        end
    end
end

-- ============================================================
-- FUNZIONE: restoreDiceUiState()
-- ============================================================
function restoreDiceUiState()

    if not DICE_CONTEST or not diceUrls then return end

    local resetUrl = diceUrls[1]

    if DICE_CONTEST.rolledNumberArmy1 then
        UI.setAttribute("diceArmy1", "image", diceUrls[DICE_CONTEST.rolledNumberArmy1])
    else
        UI.setAttribute("diceArmy1", "image", resetUrl)
    end

    if DICE_CONTEST.rolledNumberArmy2 then
        UI.setAttribute("diceArmy2", "image", diceUrls[DICE_CONTEST.rolledNumberArmy2])
    else
        UI.setAttribute("diceArmy2", "image", resetUrl)
    end
end
end)
__bundle_register("rulesets.lionheart.phases", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- FUNZIONE: initPhases()
-- ============================================================
function initPhases()

    if DEBUG then print("lionheart_initPhases") end

    linee_rettangolo = true
    linee_deploy     = false

    local phases_json = [[
    {
        "SITTING": {
            "title": "PHASE: SITTING",
            "desc": "Select both players",
            "before": "before_sitting",
            "after": "after_sitting",
            "allowedActions": ["ARMY1_CLICK", "ARMY2_CLICK"],
            "render": "2BtnClick",
            "enforceOwnership": false,
            "inputMode": "FREE",
            "buttons": {
                "BTN_ARMY1": {
                    "action": "ARMY1_CLICK",
                    "label": "Select Red",
                    "textColor": "White",
                     "color": "Red",
                    "callback": "sitting_btn_all"
                },
                "BTN_ARMY2": {
                    "action": "ARMY2_CLICK",
                    "label": "Select Green",
                    "textColor": "White",
                    "color": "Green",
                    "callback": "sitting_btn_all"
                }
            },
            "transitions": [
                {
                    "to": "DEPLOY",
                    "conditions": ["requirement_met"]
                }
            ]
        },
