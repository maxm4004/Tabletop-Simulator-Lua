__bundle_register("rulesets.lionheart.deploy.callbacks", function(require, _LOADED, __bundle_register, __bundle_modules)
-- DEPLOY — Callbacks
function deploy_btn_army1(player, value, id)
    TURN.completed.Army1 = true
    callHandler("deployment_loadArmySlot", 1, player)
    return true
end
-- ============================================================
-- FUNZIONE: deploy_btn_army2()
-- ============================================================
function deploy_btn_army2(player, value, id)
    TURN.completed.Army2 = true
    callHandler("deployment_loadArmySlot", 2, player)
    return true
end
-- ============================================================
-- FUNZIONE: deploy_position_btn_army1()
-- ============================================================
function deploy_position_btn_army1(player, value, id)
    --if not deployment_confirmDeploy(player) then return false end
    TURN.completed.Army1 = true
    callHandler("updateCenterPanel")
    return true
end
 -- ============================================================
-- FUNZIONE: deploy_position_btn_army2()
-- ============================================================
function deploy_position_btn_army2(player, value, id)
    --if not deployment_confirmDeploy(player) then return false end
    TURN.completed.Army2 = true
    callHandler("updateCenterPanel")
    return true
end
-- ============================================================
-- FUNZIONE: move_btn_army1()
-- ============================================================

end)
__bundle_register("rulesets.lionheart.deploy.hooks", function(require, _LOADED, __bundle_register, __bundle_modules)
-- DEPLOY — Hooks
function before_deploy_spawn(phaseName, phase)
    TURN.phase = phaseName
    TURN.completed = { Army1 = false, Army2 = false }
    linee_deploy = true
    callHandler("aggiornaLinee")
end      
-- ============================================================
-- FUNZIONE: after_deploy_spawn()
-- ============================================================
function after_deploy_spawn(phaseName, phase)
    TURN.completed = { Army1 = false, Army2 = false }
end
-- ============================================================
-- FUNZIONE: before_deploy_position()
-- ============================================================
function before_deploy_position(phaseName, phase)
    TURN.phase = phaseName
    TURN.completed = { Army1 = false, Army2 = false }
end
-- ============================================================
-- FUNZIONE: after_deploy_position()
-- ============================================================
function after_deploy_position(phaseName, phase)
    linee_deploy = false
    callHandler("deployment_revealAllSpawned")
    callHandler("deployment_scanTable")
    callHandler("aggiornaSchedeUnita")
end
-- ============================================================
-- FUNZIONE: before_initiative_roll()

end)
