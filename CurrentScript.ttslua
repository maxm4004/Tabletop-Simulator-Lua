__bundle_register("rulesets.lionheart.deployment.loader", function(require, _LOADED, __bundle_register, __bundle_modules)
require("rulesets.lionheart.data")
require("rulesets.lionheart.deployment.state")
require("rulesets.lionheart.deployment.config")
require("rulesets.lionheart.deployment.spawner")
require("rulesets.lionheart.deployment.army_loader")
require("rulesets.lionheart.deployment.scanner")
require("rulesets.lionheart.deployment.validator")
end)
__bundle_register("rulesets.lionheart.deployment.validator", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- LIONHEART DEPLOYMENT / VALIDATOR
-- Porting diretto di verificaDeploy
-- ============================================================
function deployment_validateDeploy()

    printToAll("[DEPLOY] verificaDeploy", {r=0.9,g=0.8,b=0.1})

    local zone = LIONHEART_DATA.deployment.zone or {}

    local X_MAX = zone.xMax
    local Z_NEAR = zone.zNear
    local Z_FAR = zone.zFar

    local errori = {
        [1] = {fuori = {}, sbagliata = {}},
        [2] = {fuori = {}, sbagliata = {}}
    }

    local basi_errate = {}

    for _, obj in ipairs(getAllObjects()) do

        local slot = deployment_getObjectArmySlot(obj)
        if slot ~= nil then

            local pos = obj.getPosition()

            local z_abs = math.abs(pos.z)
            local x_abs = math.abs(pos.x)

            local z_ok = z_abs >= Z_NEAR and z_abs <= Z_FAR
            local x_ok = x_abs <= X_MAX

            local z_sign_ok = (slot == 1 and pos.z < 0) or (slot == 2 and pos.z > 0)

            local nome = obj.getName()
            if not z_ok or not x_ok then
                table.insert(errori[slot].fuori, nome)
                table.insert(basi_errate, obj)

            elseif not z_sign_ok then
                table.insert(errori[slot].sbagliata, nome)
                table.insert(basi_errate, obj)
            end
        end
    end

    -- evidenzia errori
    for _, obj in ipairs(basi_errate) do
        if obj then
            obj.highlightOn({r=1,g=0.1,b=0.1}, 15)
        end
    end

    local totale = 0

    for slot = 1, 2 do
        local e = errori[slot]
        local n = #e.fuori + #e.sbagliata
        totale = totale + n

        if n > 0 then
            local armyName = (DEPLOYMENT.armies[slot] and DEPLOYMENT.armies[slot].displayName)
                or ("Army"..slot)

            printToAll("── Army "..slot.." ("..armyName..") ──", {r=1,g=0.8,b=0.2})

            for _, nn in ipairs(e.fuori) do
                printToAll("  Fuori zona: "..nn, {r=1,g=0.7,b=0.3})
            end

            for _, nn in ipairs(e.sbagliata) do
                printToAll("  Zona sbagliata: "..nn, {r=1,g=0.4,b=0.4})
            end
        end
    end

    -- conta basi
    local basi_trovate = 0
    for _, obj in ipairs(getAllObjects()) do
        if deployment_getObjectArmySlot(obj) ~= nil then
            basi_trovate = basi_trovate + 1
        end
    end

    if basi_trovate == 0 then
        printToAll("[DEPLOY] Nessuna base trovata!", {r=1,g=0.3,b=0.3})
        return false
    end

    if totale == 0 then
        printToAll("[DEPLOY] OK — tutte le basi nelle zone corrette!", {r=0.4,g=0.9,b=0.4})
        return true
    end

    return false
end
-- ============================================================
-- FUNZIONE: deployment_confirmDeploy
-- ============================================================
function deployment_confirmDeploy(player)
    if not deployment_areBothArmiesLoaded() then
        fadeOut("Devi caricare entrambi gli eserciti prima di confermare.")
        return false
    end

    if not LIONHEART_DATA.deployment.positioningOnTable then
        if not deployment_validateDeploy() then
            fadeOut("Correggi il posizionamento e premi di nuovo Confirm Deploy.")
            return false
        end
    end

    return true
end

function deployment_debugDrawDeployArea()
    local zone = LIONHEART_DATA.deployment.zone or {}

    local X_MAX  = zone.xMax
    local Z_NEAR = zone.zNear
    local Z_FAR  = zone.zFar
    local Y      = zone.y or 3

    local colorArmy1 = {1, 0, 0}
    local colorArmy2 = {0, 0.4, 1}

    -- Army1: zona z negativa
    deployment_debugDrawRect(
        -X_MAX, -Z_FAR,
         X_MAX, -Z_NEAR,
         Y,
         colorArmy1
    )

    -- Army2: zona z positiva
    deployment_debugDrawRect(
        -X_MAX, Z_NEAR,
         X_MAX, Z_FAR,
         Y,
         colorArmy2
    )

    printToAll("[DEPLOY DEBUG] Aree deploy tracciate", {r=0.8,g=0.8,b=0.2})
end

function deployment_debugDrawRect(x1, z1, x2, z2, y, color)
    local p1 = {x=x1, y=y, z=z1}
    local p2 = {x=x2, y=y, z=z1}
    local p3 = {x=x2, y=y, z=z2}
    local p4 = {x=x1, y=y, z=z2}

    Global.setVectorLines({
        {
            points = {p1, p2, p3, p4, p1},
            color = color,
            thickness = 0.15,
            rotation = {0,0,0}
        }
    })
end
end)
__bundle_register("rulesets.lionheart.deployment.scanner", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- LIONHEART DEPLOYMENT / SCANNER
-- Ricostruzione unità da oggetti TTS.
-- ============================================================

function deployment_scanTable()
    
    local groups = {
        [1] = {},
        [2] = {}
    }

    wounds_data = wounds_data or {}

    for _, obj in ipairs(getAllObjects()) do
        local slot = deployment_getObjectArmySlot(obj)

        if slot ~= nil then
            local baseInfo = deployment_readBaseInfo(obj, slot)

            if baseInfo ~= nil then
                local key = baseInfo.unitType .. "_" .. tostring(baseInfo.unitNumber)
                local group = groups[slot][key]

                if group == nil then
                    local unitTypeData = LIONHEART_DATA.unitTypes and LIONHEART_DATA.unitTypes[baseInfo.unitType] or {}
                    group = {
                        tipo = baseInfo.unitType,
                        unita_num = baseInfo.unitNumber,
                        valore = baseInfo.modifier,
                        arma = baseInfo.weapon,
                        fpb = unitTypeData.fpb,
                        basi_max = unitTypeData.basi,
                        fazione = tostring(slot),
                        basi = {}
                    }
                    groups[slot][key] = group
                end

                table.insert(group.basi, {
                    nickname = obj.getName(),
                    guid = obj.getGUID(),
                    seq = baseInfo.baseSeq
                })

                wounds_data[obj.getName()] = baseInfo.wounds or 0
                obj.highlightOff()
            end
        end
    end

    DEPLOYMENT.scanned[1] = deployment_groupsToList(groups[1], 1)
    DEPLOYMENT.scanned[2] = deployment_groupsToList(groups[2], 2)

    return DEPLOYMENT.scanned[1], DEPLOYMENT.scanned[2]
end

function deployment_getObjectArmySlot(obj)
    if obj == nil then return nil end

    if obj.hasTag and obj.hasTag("Army1") then return 1 end
    if obj.hasTag and obj.hasTag("Army2") then return 2 end

    local tags = obj.getTags and obj.getTags() or {}
    for _, tag in ipairs(tags) do
        if tag == "Army1" then return 1 end
        if tag == "Army2" then return 2 end
    end

    return nil
end

function deployment_readBaseInfo(obj, slot)
    local metadata = nil

    if obj.getVar ~= nil then
        local raw = obj.getVar("lh_metadata_json")

        if raw ~= nil and raw ~= "" then
            local ok, decoded = pcall(JSON.decode, raw)
            if ok and type(decoded) == "table" then
                metadata = decoded
            end
        end
    end

    if type(metadata) == "table" and metadata.kind == "UNIT_BASE" then
        local unitNumber = deployment_extractUnitNumberFromNickname(metadata.nickname or obj.getName())
        return {
            unitType = metadata.unitType,
            unitNumber = unitNumber,
            baseSeq = metadata.baseSeq,
            modifier = metadata.modifier,
            weapon = metadata.weapon,
            wounds = metadata.wounds or 0
        }
    end

    return deployment_parseNickname(obj.getName())
end

function deployment_parseNickname(nickname)
    if nickname == nil or nickname == "" then return nil end

    local unitType, unitNumber, baseSeq, rest = string.match(nickname, "^([^_]+)_(%d+)%.(%d+)_?(.*)$")
    if unitType == nil then return nil end

    local modifier = nil
    local weapon = nil

    if rest ~= nil and rest ~= "" then
        local p1, p2 = string.match(rest, "^([^_]+)_?(.*)$")
        modifier = p1
        if p2 ~= nil and p2 ~= "" then weapon = p2 end
    end

    return {
        unitType = unitType,
        unitNumber = tonumber(unitNumber),
        baseSeq = tonumber(baseSeq),
        modifier = modifier,
        weapon = weapon,
        wounds = wounds_data and wounds_data[nickname] or 0
    }
end

function deployment_extractUnitNumberFromNickname(nickname)
    local _, n = string.match(nickname or "", "^([^_]+)_(%d+)")
    return tonumber(n) or 1
end

function deployment_groupsToList(groups, slot)
    local list = {}

    for _, unit in pairs(groups) do
        local armyMeta = DEPLOYMENT.armies and DEPLOYMENT.armies[slot] or nil
        local armyTag = armyMeta and armyMeta.tag or ("ARMY" .. tostring(slot))

        unit.nome_display = armyTag .. "_" .. unit.tipo .. "_" .. tostring(unit.unita_num)

        table.sort(unit.basi, function(a, b)
            return (a.seq or 0) < (b.seq or 0)
        end)

        table.insert(list, unit)
    end

    table.sort(list, function(a, b)
        if a.tipo ~= b.tipo then return a.tipo < b.tipo end
        return (a.unita_num or 0) < (b.unita_num or 0)
    end)

    return list
end

end)
__bundle_register("rulesets.lionheart.deployment.army_loader", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- LIONHEART DEPLOYMENT / ARMY LOADER
-- Callback ponte -> load army slot.
-- ============================================================

function deployment_loadArmySlot(slot, player)
    
    slot = tonumber(slot)

    if not deployment_isValidSlot(slot) then
        printToAll("[DEPLOY] slot esercito non valido: " .. tostring(slot), {r=1,g=0.3,b=0.3})
        return false
    end

    if deployment_isArmyLoaded(slot) then
        printToAll("[DEPLOY] Army" .. slot .. " già caricata", {r=1,g=0.8,b=0.2})
        return false
    end

    if deployment_isBusy(slot) then
        printToAll("[DEPLOY] Army" .. slot .. " già in caricamento", {r=1,g=0.8,b=0.2})
        return false
    end

    local function doLoad()
        local url = deployment_getArmyUrl(slot)
        if url == nil or url == "" then
            printToAll("[DEPLOY] URL Army" .. slot .. " non configurato", {r=1,g=0.3,b=0.3})
            return false
        end

        deployment_setBusy(slot, true)

        local playerName = player and player.steam_name or "---"
        local playerColor = player and player.color or "---"

        printToAll("[DEPLOY] Download Army" .. slot .. "...", {r=0.8,g=0.8,b=0.8})

        WebRequest.get(url, function(req)
            if req.is_error then
                deployment_setBusy(slot, false)
                deployment_addError("Errore Army" .. slot .. ": " .. tostring(req.error))
                printToAll("[DEPLOY] Errore Army" .. slot .. ": " .. tostring(req.error), {r=1,g=0.3,b=0.3})
                return
            end

            local ok, armyData = pcall(JSON.decode, req.text)
            if not ok or type(armyData) ~= "table" then
                deployment_setBusy(slot, false)
                deployment_addError("Parsing Army" .. slot .. " fallito")
                printToAll("[DEPLOY] Parsing Army" .. slot .. " fallito", {r=1,g=0.3,b=0.3})
                return
            end

            if not deployment_validateArmyData(slot, armyData) then
                deployment_setBusy(slot, false)
                return
            end

            deployment_applyArmyPlayer(slot, playerName, playerColor)

            local spawned = deployment_spawnArmy(slot, armyData)
            deployment_markArmyLoaded(slot, spawned == true)
            deployment_setBusy(slot, false)

            if spawned then
                printToAll("[DEPLOY] Army" .. slot .. " caricata", {r=0.4,g=0.9,b=0.4})
            end

            if updateCenterPanel then updateCenterPanel() end
        end)

        return true
    end

    if DEPLOYMENT.initialized then
        return doLoad()
    end

    deployment_init(function(ok)
        if ok then doLoad() end
    end)

    return true
end

function deployment_validateArmyData(slot, armyData)
    if armyData.unita == nil or type(armyData.unita) ~= "table" then
        deployment_addError("Army" .. tostring(slot) .. " senza array unita")
        printToAll("[DEPLOY] Army" .. tostring(slot) .. " senza array unita", {r=1,g=0.3,b=0.3})
        return false
    end
    return true
end

function deployment_applyArmyPlayer(slot, playerName, playerColor)
    DEPLOYMENT.armies[slot] = DEPLOYMENT.armies[slot] or {}
    DEPLOYMENT.armies[slot].player = playerName
    DEPLOYMENT.armies[slot].color = playerColor

    -- Compatibilità soft con vecchio ARMY, se esiste.
    if ARMY ~= nil and ARMY[slot] ~= nil then
        ARMY[slot].player = playerName
        ARMY[slot].color = playerColor
    end
end

end)
__bundle_register("rulesets.lionheart.deployment.spawner", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- LIONHEART DEPLOYMENT / SPAWNER
-- Porting pulito di generaUnitaFromJson.
-- ============================================================

function deployment_spawnArmy(slot, armyData)
    if armyData == nil then
        printToAll("[DEPLOY] armyData nullo", {r=1,g=0.3,b=0.3})
        return false
    end

    local armyTag = deployment_getArmyTag(slot)
    local counters = {}

    deployment_applyArmyMeta(slot, armyData)

    for _, unitData in ipairs(armyData.unita or {}) do
        deployment_spawnUnit(slot, armyTag, unitData, counters)
    end

    return true
end

function deployment_applyArmyMeta(slot, armyData)
    DEPLOYMENT.armies[slot] = DEPLOYMENT.armies[slot] or {}
    DEPLOYMENT.armies[slot].tag = armyData.tag
    DEPLOYMENT.armies[slot].name = armyData.nome
    DEPLOYMENT.armies[slot].displayName = armyData.nome_display

    -- Compatibilità soft con vecchio ARMY, se presente.
    if ARMY ~= nil and ARMY[slot] ~= nil then
        ARMY[slot].tag = armyData.tag
        ARMY[slot].nome = armyData.nome
        ARMY[slot].nome_display = armyData.nome_display
    end
end

function deployment_spawnUnit(slot, armyTag, unitData, counters)
    if unitData == nil then return end

    local unitType = unitData.tipo
    if unitType == nil then
        printToAll("[DEPLOY] unità senza tipo", {r=1,g=0.3,b=0.3})
        return
    end

    counters[unitType] = (counters[unitType] or 0) + 1
    local unitNumber = counters[unitType]

    for _, baseData in ipairs(unitData.basi or {}) do
        deployment_spawnBase(slot, armyTag, unitData, baseData, unitNumber)
    end
end

function deployment_spawnBase(slot, armyTag, unitData, baseData, unitNumber)
    if baseData == nil then return end

    local templateKey = deployment_getTemplateKey(unitData, baseData)
    local templateData = deployment_getTemplate(templateKey)

    if templateData == nil then
        printToAll("[DEPLOY] template non trovato: " .. tostring(templateKey), {r=1,g=0.3,b=0.3})
        return
    end

    local nickname = deployment_buildBaseNickname(unitData, baseData, unitNumber)
    local pos = deployment_buildBasePosition(slot, baseData)
    local rot = deployment_buildBaseRotation(slot)

    local spawnParams = deployment_buildSpawnParams(nickname, unitData, templateData, pos, rot)

    spawnObjectJSON({
        json = JSON.encode(spawnParams),
        callback_function = function(obj)
            deployment_onBaseSpawned(obj, slot, armyTag, nickname, unitData, baseData)
        end
    })
end

function deployment_getTemplateKey(unitData, baseData)
    return baseData.model or unitData.model or baseData.template or unitData.template or unitData.tipo
end

function deployment_getTemplate(templateKey)
    if templateKey == nil then return nil end

    local key = tostring(templateKey)

    if DEPLOYMENT.templateIndex and DEPLOYMENT.templateIndex[key] then
        return DEPLOYMENT.templateIndex[key]
    end

    if DEPLOYMENT.templates and DEPLOYMENT.templates[key] then
        return DEPLOYMENT.templates[key]
    end

    -- Fallback stile vecchio getByNameFromJson su lista.
    if type(DEPLOYMENT.templates) == "table" then
        for _, t in ipairs(DEPLOYMENT.templates) do
            if type(t) == "table" then
                local name = t.name or t.nome or t.id or t.key or t.tipo or t.model
                if tostring(name) == key then
                    return t
                end
            end
        end
    end

    return nil
end

function deployment_buildBaseNickname(unitData, baseData, unitNumber)
    local nickname = tostring(unitData.tipo) .. "_" .. tostring(unitNumber) .. "." .. tostring(baseData.seq)

    if unitData.modificatore ~= nil then
        nickname = nickname .. "_" .. tostring(unitData.modificatore)
    end

    if baseData.arma ~= nil then
        nickname = nickname .. "_" .. tostring(baseData.arma)
    end

    return nickname
end

function deployment_buildBasePosition(slot, baseData)
    local deploy = LIONHEART_DATA.deployment or {}
    local offsetZ = deploy.offsetZ or 45.00
    local y = deploy.spawnY or 1.70

    local sourcePos = baseData.posizione or {x=0, z=0}
    local zOffset = tonumber(slot) == 1 and -offsetZ or offsetZ

    return {
        x = sourcePos.x or 0,
        y = y,
        z = (sourcePos.z or 0) + zOffset
    }
end

function deployment_buildBaseRotation(slot)
    return {
        x = 0,
        y = tonumber(slot) == 1 and 0 or 180,
        z = 0
    }
end

function deployment_buildSpawnParams(nickname, unitData, templateData, pos, rot)
    local mesh = templateData.customMesh or templateData.CustomMesh

    if mesh ~= nil then
        mesh.MaterialIndex = 3
    end

    return {
        name = "Custom_Model",
        nickname = nickname,
        description = unitData.nome_display or "",
        Transform = {
            posX = pos.x,
            posY = pos.y,
            posZ = pos.z,
            rotX = rot.x,
            rotY = rot.y,
            rotZ = rot.z,
            scaleX = 1,
            scaleY = 1,
            scaleZ = 1
        },
        CustomMesh = mesh
    }
end

function deployment_onBaseSpawned(obj, slot, armyTag, nickname, unitData, baseData)
    
    if obj == nil then
        printToAll("[DEPLOY] spawn fallito: " .. tostring(nickname), {r=1,g=0.3,b=0.3})
        return
    end

    Wait.frames(function()
        if obj == nil then return end

        obj.setName(nickname)
        obj.setDescription(unitData.nome_display or "")
        obj.setLock(true)
        obj.auto_raise = true

        local finalArmyTag = armyTag or deployment_getArmyTag(slot)

        obj.addTag(finalArmyTag)

        deployment_applyBaseMetadata(obj, slot, finalArmyTag, nickname, unitData, baseData)
        deployment_applyBaseVisibility(obj, slot)
        deployment_applyBaseWounds(obj, nickname, unitData, baseData)

        Wait.time(function()
            if obj ~= nil then
                obj.setLock(false)
            end
        end, 1.0)
    end, 2)
end

function deployment_applyBaseTags(obj, slot, armyTag, unitData, baseData)
    obj.addTag(armyTag)
end

function deployment_applyBaseMetadata(obj, slot, armyTag, nickname, unitData, baseData)
    local metadata = {
        ruleset = "LIONHEART",
        kind = "UNIT_BASE",
        armySlot = tonumber(slot),
        armyTag = armyTag,
        nickname = nickname,
        unitType = unitData.tipo,
        unitName = unitData.nome_display,
        baseSeq = baseData.seq,
        modifier = unitData.modificatore,
        weapon = baseData.arma,
        wounds = baseData.ferite or 0
    }

    obj.setVar("lh_metadata_json", JSON.encode(metadata))
end

function deployment_applyBaseVisibility(obj, slot)
    if DEBUG then return end

    local enemySlot = tonumber(slot) == 1 and 2 or 1
    local enemyColor = nil

    if DEPLOYMENT.armies and DEPLOYMENT.armies[enemySlot] then
        enemyColor = DEPLOYMENT.armies[enemySlot].color
    end

    if (enemyColor == nil or enemyColor == "---") and ARMY ~= nil and ARMY[enemySlot] ~= nil then
        enemyColor = ARMY[enemySlot].color
    end

    if enemyColor ~= nil and enemyColor ~= "---" then
        obj.setInvisibleTo({enemyColor})
    end
end

function deployment_applyBaseWounds(obj, nickname, unitData, baseData)
    local wounds = baseData.ferite or 0

    wounds_data = wounds_data or {}
    wounds_data[nickname] = wounds

    if wounds <= 0 then
        if aggiornaTagInjured ~= nil then
            aggiornaTagInjured(obj, 0)
        end
        return
    end

    local unitTypeData = LIONHEART_DATA.unitTypes and LIONHEART_DATA.unitTypes[unitData.tipo] or nil
    local fpb = unitTypeData and unitTypeData.fpb or 3

    if aggiornaTintaBase ~= nil then
        aggiornaTintaBase(obj, wounds, fpb)
    end

    if aggiornaTagInjured ~= nil then
        aggiornaTagInjured(obj, wounds)
    end
end

function deployment_clearSpawnedModels()

    printToAll("[DEPLOY] Rimozione modelli spawnati...", {r=0.8,g=0.8,b=0.2})

    local removed = 0

    for _, obj in ipairs(getAllObjects()) do

        -- Metodo robusto: usa tag
        if deployment_isSpawnedUnit(obj) then
            obj.destruct()
            removed = removed + 1
        end
    end

    printToAll("[DEPLOY] Rimossi "..removed.." oggetti", {r=0.4,g=0.9,b=0.4})
end

function deployment_isSpawnedUnit(obj)
    if obj == nil then return false end

    if obj.hasTag then
        if obj.hasTag("Army1") or obj.hasTag("Army2") then
            return true
        end
    end

    return false
end

function deployment_revealAllSpawned()

    print("deployment_revealAllSpawned")

    for _, obj in ipairs(getAllObjects()) do
        if deployment_getObjectArmySlot(obj) ~= nil then
            obj.setInvisibleTo({})
        end
    end
end

end)
__bundle_register("rulesets.lionheart.deployment.config", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- LIONHEART DEPLOYMENT / CONFIG
-- Caricamento remoto main/config/regolamento/template.
-- ============================================================

function deployment_init(callback)
    if DEPLOYMENT.initialized == true then
        if callback then callback(true) end
        return
    end

    if DEPLOYMENT.loading == true then
        if callback then callback(false) end
        return
    end

    DEPLOYMENT.loading = true

    deployment_loadMainConfig(function(okMain)
        deployment_loadRulesetData(function(okRules)
            deployment_loadRuntimeConfig(function(okConfig)
                deployment_loadTemplates(function(okTemplates)
                    DEPLOYMENT.loading = false
                    DEPLOYMENT.initialized = okMain and okRules and okTemplates

                    if DEPLOYMENT.initialized then
                        printToAll("[DEPLOY] configurazione deployment pronta", {r=0.4,g=0.9,b=0.4})
                    else
                        printToAll("[DEPLOY] configurazione deployment incompleta", {r=1,g=0.6,b=0})
                    end

                    if callback then callback(DEPLOYMENT.initialized) end
                end)
            end)
        end)
    end)
end

function deployment_loadMainConfig(callback)
    local url = DEPLOYMENT.urls.main

    if url == nil or url == "" then
        deployment_addError("MAIN_URL non configurato")
        if callback then callback(false) end
        return
    end

    WebRequest.get(url, function(req)
        if req.is_error then
            deployment_addError("Errore main.json: " .. tostring(req.error))
            printToAll("[DEPLOY] Errore main.json: " .. tostring(req.error), {r=1,g=0.3,b=0.3})
            if callback then callback(false) end
            return
        end

        local ok, data = pcall(JSON.decode, req.text)
        if not ok or type(data) ~= "table" then
            deployment_addError("Parsing main.json fallito")
            printToAll("[DEPLOY] Parsing main.json fallito", {r=1,g=0.3,b=0.3})
            if callback then callback(false) end
            return
        end

        DEPLOYMENT.urls.regolamento      = data.REGOLAMENTO_URL or DEPLOYMENT.urls.regolamento
        DEPLOYMENT.urls.config           = data.CONFIG_URL or DEPLOYMENT.urls.config
        DEPLOYMENT.urls.army1            = data.ARMY1_URL or DEPLOYMENT.urls.army1
        DEPLOYMENT.urls.army2            = data.ARMY2_URL or DEPLOYMENT.urls.army2
        DEPLOYMENT.urls.elementiScenario = data.ELEMENTI_SCENARIO_URL or DEPLOYMENT.urls.elementiScenario
        DEPLOYMENT.urls.grounds          = data.GROUNDS_URL or DEPLOYMENT.urls.grounds
        DEPLOYMENT.urls.template         = data.TEMPLATE_URL or DEPLOYMENT.urls.template

        if callback then callback(true) end
    end)
end

function deployment_loadRulesetData(callback)
    local url = DEPLOYMENT.urls.regolamento

    if url == nil or url == "" then
        deployment_addError("REGOLAMENTO_URL non configurato")
        if callback then callback(false) end
        return
    end

    WebRequest.get(url, function(req)
        if req.is_error then
            deployment_addError("Errore regolamento: " .. tostring(req.error))
            printToAll("[DEPLOY] Errore regolamento: " .. tostring(req.error), {r=1,g=0.3,b=0.3})
            if callback then callback(false) end
            return
        end

        local ok, data = pcall(JSON.decode, req.text)
        if not ok or type(data) ~= "table" then
            deployment_addError("Parsing regolamento fallito")
            printToAll("[DEPLOY] Parsing regolamento fallito", {r=1,g=0.3,b=0.3})
            if callback then callback(false) end
            return
        end

        LIONHEART_DATA.phases = data.fasi or {}
        LIONHEART_DATA.unitTypes = data.dati_unita or {}
        LIONHEART_DATA.shootingWeapons = data.armi_tiro or {}

        if callback then callback(true) end
    end)
end

function deployment_loadRuntimeConfig(callback)
    local url = DEPLOYMENT.urls.config

    if url == nil or url == "" then
        if callback then callback(true) end
        return
    end

    WebRequest.get(url, function(req)
        if req.is_error then
            deployment_addError("Errore config: " .. tostring(req.error))
            printToAll("[DEPLOY] Errore config: " .. tostring(req.error), {r=1,g=0.3,b=0.3})
            if callback then callback(false) end
            return
        end

        local ok, data = pcall(JSON.decode, req.text)
        if not ok or type(data) ~= "table" then
            deployment_addError("Parsing config fallito")
            printToAll("[DEPLOY] Parsing config fallito", {r=1,g=0.3,b=0.3})
            if callback then callback(false) end
            return
        end

        LIONHEART_DATA.config.visualizzazioneFerite = data.visualizzazione_ferite
        LIONHEART_DATA.config.coloreUnitaBersaglioTiro = data.colore_bersaglio_tiro

        LIONHEART_DATA.deployment.positioningOnTable = data.posizionamento_su_tavolo
        LIONHEART_DATA.deployment.deployCm = data.deploy_cm

        if data.spawn_y then LIONHEART_DATA.deployment.spawnY = data.spawn_y end
        if data.offset_z then LIONHEART_DATA.deployment.offsetZ = data.offset_z end

        if data.army1_url then DEPLOYMENT.urls.army1 = data.army1_url end
        if data.army2_url then DEPLOYMENT.urls.army2 = data.army2_url end

        if data.verde then
            LIONHEART_DATA.table.green = {
                y = data.verde.y,
                yLines = data.verde.y_linee,
                lx = data.verde.lx,
                lz = data.verde.lz
            }
        end

        if data.tavolo then
            LIONHEART_DATA.table.board = {
                y = data.tavolo.y,
                lx = data.tavolo.lx,
                lz = data.tavolo.lz
            }
        end

        if callback then callback(true) end
    end)
end

function deployment_loadTemplates(callback)
    local url = DEPLOYMENT.urls.template

    if url == nil or url == "" then
        deployment_addError("TEMPLATE_URL non configurato")
        if callback then callback(false) end
        return
    end

    WebRequest.get(url, function(req)
        if req.is_error then
            deployment_addError("Errore template: " .. tostring(req.error))
            printToAll("[DEPLOY] Errore template: " .. tostring(req.error), {r=1,g=0.3,b=0.3})
            if callback then callback(false) end
            return
        end

        local ok, data = pcall(JSON.decode, req.text)
        if not ok or data == nil then
            deployment_addError("Parsing template fallito")
            printToAll("[DEPLOY] Parsing template fallito", {r=1,g=0.3,b=0.3})
            if callback then callback(false) end
            return
        end

        DEPLOYMENT.templates = data
        deployment_buildTemplateIndex()

        if callback then callback(true) end
    end)
end

function deployment_buildTemplateIndex()
    DEPLOYMENT.templateIndex = {}

    local templates = DEPLOYMENT.templates
    if type(templates) ~= "table" then return end

    if type(templates.Army) == "table" then
        for _, army in ipairs(templates.Army) do
            if type(army) == "table" and type(army.modelli) == "table" then
                for _, model in ipairs(army.modelli) do
                    if type(model) == "table" then
                        if model.nickname then
                            DEPLOYMENT.templateIndex[tostring(model.nickname)] = model
                        end

                        if model.name then
                            DEPLOYMENT.templateIndex[tostring(model.name)] = model
                        end
                    end
                end
            end
        end
    end

    -- fallback mappa semplice
    for k, v in pairs(templates) do
        if type(k) == "string" and type(v) == "table" then
            DEPLOYMENT.templateIndex[k] = v
        end
    end
end
end)
__bundle_register("rulesets.lionheart.deployment.state", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- LIONHEART DEPLOYMENT / STATE
-- Stato runtime del deploy.
-- ============================================================

DEPLOYMENT = DEPLOYMENT or {
    initialized = false,
    loading = false,

    urls = {
        main = "https://raw.githubusercontent.com/maxm4004/Tabletop-Simulator-Lua/refs/heads/main/Json/main.json",
        regolamento = "",
        config = "",
        army1 = "",
        army2 = "",
        elementiScenario = "",
        grounds = "",
        template = ""
    },

    templates = {},
    templateIndex = {},

    armies = {
        [1] = nil,
        [2] = nil
    },

    armyLoaded = {
        [1] = false,
        [2] = false
    },

    armyBusy = {
        [1] = false,
        [2] = false
    },

    scanned = {
        [1] = {},
        [2] = {}
    },

    errors = {}
}

function deployment_reset()
    DEPLOYMENT.initialized = false
    DEPLOYMENT.loading = false
    DEPLOYMENT.templates = {}
    DEPLOYMENT.templateIndex = {}
    DEPLOYMENT.armies = { [1] = nil, [2] = nil }
    DEPLOYMENT.armyLoaded = { [1] = false, [2] = false }
    DEPLOYMENT.armyBusy = { [1] = false, [2] = false }
    DEPLOYMENT.scanned = { [1] = {}, [2] = {} }
    DEPLOYMENT.errors = {}
end

function deployment_resetRuntimeOnly()
    DEPLOYMENT.armies = { [1] = nil, [2] = nil }
    DEPLOYMENT.armyLoaded = { [1] = false, [2] = false }
    DEPLOYMENT.armyBusy = { [1] = false, [2] = false }
    DEPLOYMENT.scanned = { [1] = {}, [2] = {} }
    DEPLOYMENT.errors = {}
end

function deployment_isValidSlot(slot)
    local s = tonumber(slot)
    return s == 1 or s == 2
end

function deployment_isArmyLoaded(slot)
    if not deployment_isValidSlot(slot) then return false end
    return DEPLOYMENT.armyLoaded[tonumber(slot)] == true
end

function deployment_markArmyLoaded(slot, value)
    if not deployment_isValidSlot(slot) then return end
    DEPLOYMENT.armyLoaded[tonumber(slot)] = value ~= false
end

function deployment_isBusy(slot)
    if not deployment_isValidSlot(slot) then return false end
    return DEPLOYMENT.armyBusy[tonumber(slot)] == true
end

function deployment_setBusy(slot, value)
    if not deployment_isValidSlot(slot) then return end
    DEPLOYMENT.armyBusy[tonumber(slot)] = value == true
end

function deployment_areBothArmiesLoaded()
    return DEPLOYMENT.armyLoaded[1] == true and DEPLOYMENT.armyLoaded[2] == true
end

function deployment_addError(message)
    DEPLOYMENT.errors = DEPLOYMENT.errors or {}
    table.insert(DEPLOYMENT.errors, tostring(message))
end

function deployment_getArmyTag(slot)
    return "Army" .. tostring(slot)
end

function deployment_getArmyUrl(slot)
    if tonumber(slot) == 1 then return DEPLOYMENT.urls.army1 end
    if tonumber(slot) == 2 then return DEPLOYMENT.urls.army2 end
    return nil
end

end)
