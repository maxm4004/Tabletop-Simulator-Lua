-- ============================================================
-- FUNZIONE: rulesetInit()
-- ============================================================
function rulesetInit(save_state)
    
    lionheart_loadButtonBar(function(ok)
        -- slots popolati, ora buildUI genera XML con label già dentro
        callHandler("initPhases")
        callHandler("autoRegisterFromPhases")
        callHandler("registerDefaultConditions")

        if save_state and save_state ~= "" then
            callHandler("restoreState", save_state)
        end

        engine_init()  -- chiama buildUI che usa ENGINE_BUTTONBAR.slots già pronti

        if save_state and save_state ~= "" then
            Wait.time(function()
                callHandler("afterRestoreState", save_state)
            end, 1)
        end
    end)
end
-- ============================================================
-- FUNZIONE: aggiornaTintaBase
-- ============================================================
VISUALIZZAZIONE_FERITE = "tint"  -- o "highlight"

function aggiornaTintaBase(obj, wounds, fpb)
    if wounds < 1 then
        if VISUALIZZAZIONE_FERITE == "highlight" then obj.highlightOff() else obj.setColorTint({r=1,g=1,b=1}) end
        aggiornaTagInjured(obj, 0)
        return
    end
    local colore
    if wounds == 1     then colore = {r=1,   g=0.75, b=0.39}
    elseif wounds == 2 then colore = {r=1,   g=0.55, b=0}
    else                    colore = {r=0.71,g=0.33, b=0}
    end
    if VISUALIZZAZIONE_FERITE == "highlight" then obj.highlightOn(colore) else obj.setColorTint(colore) end
    aggiornaTagInjured(obj, wounds)
    obj.setDescription("Wounds: " .. wounds .. "/" .. fpb)
end
-- ============================================================
-- FUNZIONE: aggiornaTagInjured
-- ============================================================
function aggiornaTagInjured(obj, wounds)
    obj.removeTag("injured1")
    obj.removeTag("injured2")
    obj.removeTag("injured3")
    if wounds == 1     then obj.addTag("injured1")
    elseif wounds == 2 then obj.addTag("injured2")
    elseif wounds >= 3 then obj.addTag("injured3") end
end

function deployment_parseNickname(nickname)
    if nickname == nil or nickname == "" then return nil end

    local unitType, unitNumber, baseSeq, rest = string.match(nickname, "^([^_]+)_(%d+)%.(%d+)_?(.*)$")
    if unitType == nil then return nil end

    local modifier = nil
    local weapon = nil

    if rest ~= nil and rest ~= "" then
        local p1, p2 = string.match(rest, "^([^_]+)_?(.*)$")
        modifier = p1
        if p2 ~= nil and p2 ~= "" then weapon = p2 end
    end

    return {
        unitType = unitType,
        unitNumber = tonumber(unitNumber),
        baseSeq = tonumber(baseSeq),
        modifier = modifier,
        weapon = weapon,
        wounds = wounds_data and wounds_data[nickname] or 0
    }
end
-- ============================================================
-- FUNZIONE: lionheart_findUnit(slot, tipo, unita_num)
-- Trova un'unità in DEPLOYMENT.scanned
-- ============================================================
function lionheart_findUnit(slot, tipo, unita_num)
    local esercito = DEPLOYMENT.scanned and DEPLOYMENT.scanned[slot]
    if not esercito then return nil end

    for _, u in ipairs(esercito) do
        if u.tipo == tipo and u.unita_num == unita_num then
            return u
        end
    end
    return nil
end

function deployment_scanTable()
    
    local groups = {
        [1] = {},
        [2] = {}
    }

    wounds_data = wounds_data or {}

    for _, obj in ipairs(getAllObjects()) do
        local slot = deployment_getObjectArmySlot(obj)

        if slot ~= nil then
            local baseInfo = deployment_readBaseInfo(obj, slot)

            if baseInfo ~= nil then
                local key = baseInfo.unitType .. "_" .. tostring(baseInfo.unitNumber)
                local group = groups[slot][key]

                if group == nil then
                    local unitTypeData = LIONHEART_DATA.unitTypes and LIONHEART_DATA.unitTypes[baseInfo.unitType] or {}
                    group = {
                        tipo = baseInfo.unitType,
                        unita_num = baseInfo.unitNumber,
                        valore = baseInfo.modifier,
                        arma = baseInfo.weapon,
                        fpb = unitTypeData.fpb,
                        basi_max = unitTypeData.basi,
                        fazione = tostring(slot),
                        basi = {}
                    }
                    groups[slot][key] = group
                end

                table.insert(group.basi, {
                    nickname = obj.getName(),
                    guid = obj.getGUID(),
                    seq = baseInfo.baseSeq
                })

                wounds_data[obj.getName()] = baseInfo.wounds or 0
                obj.highlightOff()
            end
        end
    end

    DEPLOYMENT.scanned[1] = deployment_groupsToList(groups[1], 1)
    DEPLOYMENT.scanned[2] = deployment_groupsToList(groups[2], 2)

    return DEPLOYMENT.scanned[1], DEPLOYMENT.scanned[2]
    
end

function deployment_revealAllSpawned()

    print("deployment_revealAllSpawned")

    for _, obj in ipairs(getAllObjects()) do
        if deployment_getObjectArmySlot(obj) ~= nil then
            obj.setInvisibleTo({})
        end
    end
end

function deployment_resetRuntimeOnly()
    DEPLOYMENT.armies = { [1] = nil, [2] = nil }
    DEPLOYMENT.armyLoaded = { [1] = false, [2] = false }
    DEPLOYMENT.armyBusy = { [1] = false, [2] = false }
    DEPLOYMENT.scanned = { [1] = {}, [2] = {} }
    DEPLOYMENT.errors = {}
end

function deployment_clearSpawnedModels()

    printToAll("[DEPLOY] Rimozione modelli spawnati...", {r=0.8,g=0.8,b=0.2})

    local removed = 0

    for _, obj in ipairs(getAllObjects()) do

        -- Metodo robusto: usa tag
        if deployment_isSpawnedUnit(obj) then
            obj.destruct()
            removed = removed + 1
        end
    end

    printToAll("[DEPLOY] Rimossi "..removed.." oggetti", {r=0.4,g=0.9,b=0.4})
end

function deployment_getObjectArmySlot(obj)
    if obj == nil then return nil end

    if obj.hasTag and obj.hasTag("Army1") then return 1 end
    if obj.hasTag and obj.hasTag("Army2") then return 2 end

    local tags = obj.getTags and obj.getTags() or {}
    for _, tag in ipairs(tags) do
        if tag == "Army1" then return 1 end
        if tag == "Army2" then return 2 end
    end

    return nil
end

function deployment_groupsToList(groups, slot)

    local list = {}

    for _, unit in pairs(groups) do
        local armyMeta = DEPLOYMENT.armies and DEPLOYMENT.armies[slot] or nil
        local armyTag = armyMeta and armyMeta.tag or ("ARMY" .. tostring(slot))

        unit.nome_display = armyTag .. "_" .. unit.tipo .. "_" .. tostring(unit.unita_num)

        table.sort(unit.basi, function(a, b)
            return (a.seq or 0) < (b.seq or 0)
        end)

        table.insert(list, unit)
    end

    table.sort(list, function(a, b)
        if a.tipo ~= b.tipo then return a.tipo < b.tipo end
        return (a.unita_num or 0) < (b.unita_num or 0)
    end)

    return list
end

function goToPhase(phaseName)
    if not ENGINE or not ENGINE.phases then return end
    if not ENGINE.phases[phaseName] then
        print("[GOTO] Phase not found: " .. phaseName)
        return
    end
    local oldPhase = ENGINE.phase
    engine_exitPhase(oldPhase)
    ENGINE.phase = phaseName
    engine_resetState()
    engine_enterPhase(phaseName, oldPhase)
    callHandler("updateCenterPanel")
end

-- ============================================================
-- FUNZIONE: lionheart_infoUnita()
-- ============================================================
function lionheart_infoUnita(player, value, id, buttonConfig)

    local selected = lionheart_getSelectedObjects(player)
    if not selected or #selected < 1 then
        printToColor("[INFO] Select a unit", player.color, {r=1,g=0.6,b=0})
        return false
    end

    local obj = selected[1]

    -- Verifica che l'unità appartenga all'esercito del player
    local playerSlot = getArmyByColor(player)
    if playerSlot == nil then return false end

    local armyTag = "Army" .. tostring(playerSlot)

    if not obj.hasTag(armyTag) then
        printToColor("[INFO] Not your unit", player.color, {r=1,g=0.3,b=0.3})
        return false
    end

    mostraPopupUnita(obj, player)
    return true
end

-- ============================================================
-- FUNZIONE: lionheart_getSelectedObjects()
-- ============================================================
function lionheart_getSelectedObjects(player)

    if player then
        local selected = Player[player.color].getSelectedObjects()
        if selected and #selected > 0 then return selected end
        return {}
    end

    -- fallback senza player (comportamento precedente)
    for _, p in ipairs(getSeatedPlayers()) do
        local selected = Player[p.color].getSelectedObjects()
        if selected and #selected > 0 then return selected end
    end
    return {}
end
