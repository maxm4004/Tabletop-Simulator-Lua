-- ============================================================
-- FUNZIONE: lionheart_applyFormation()
-- ============================================================
function lionheart_applyFormation(mode, player)

    local selected = lionheart_getSelectedObjects(player)
    if selected == nil or #selected < 2 then
        printToAll("[FORMAZIONE] Seleziona almeno 2 basi", {r=1,g=0.6,b=0})
        return false
    end

    local leader = selected[1]
    local right = leader.getTransformRight()
    local forward = leader.getTransformForward()

    for i = 2, #selected do
        local obj = selected[i]
        local index = i - 1
        local pos = nil

        if mode == "lineLeft" then
            pos = leader.getPosition() - right * (LIONHEART_FORMATION.horizontalSpacing * index)
        elseif mode == "lineRight" then
            pos = leader.getPosition() + right * (LIONHEART_FORMATION.horizontalSpacing * index)
        elseif mode == "columnUp" then
            pos = leader.getPosition() + forward * (LIONHEART_FORMATION.verticalSpacing * index)
        elseif mode == "columnDown" then
            pos = leader.getPosition() - forward * (LIONHEART_FORMATION.verticalSpacing * index)
        end

        if pos ~= nil then
            obj.setPosition(pos)
            obj.setRotation(leader.getRotation())
        end
    end

    return true
end

function aggiornaPopupUnita(slot, tipo, unita_num)
    local esercito = DEPLOYMENT.scanned and DEPLOYMENT.scanned[slot]
    if not esercito then return end

    -- Se passati tipo e unita_num aggiorna solo quell'unità
    -- altrimenti aggiorna la prima trovata
    local unita = nil
    if tipo and unita_num then
        unita = lionheart_findUnit(slot, tipo, unita_num)
    else
        unita = esercito[1]
    end

    if not unita then return end

    local p      = "unit_popup_" .. slot
    local fpb    = (LIONHEART_DATA.unitTypes[unita.tipo] or {}).fpb or 1
    local fig_att  = lionheart_figureTotaliUnita(unita)
    local fig_max  = (unita.basi_max or #unita.basi) * fpb
    local basi_p   = lionheart_basiPresentiUnita(unita)
    local basi_max = unita.basi_max or #unita.basi
    local perc     = fig_max > 0 and (fig_att / fig_max) or 0

    local salute
    if perc == 1.0    then salute = "Healthy"
    elseif perc > 0.5 then salute = "Weakened"
    elseif perc > 0   then salute = "Critical"
    else                   salute = "Destroyed" end

    UI.setAttribute(p .. "_basi",   "text", "Bases:  " .. basi_p  .. " / " .. basi_max)
    UI.setAttribute(p .. "_figure", "text", "Figs:   " .. fig_att .. " / " .. fig_max)
    UI.setAttribute(p .. "_salute", "text", "Status: " .. salute)

    print("[POPUP] fig_att=" .. tostring(fig_att) .. " fig_max=" .. tostring(fig_max))
    for _, base in ipairs(unita.basi) do
        print("[POPUP] base=" .. tostring(base.nickname) .. " wounds=" .. tostring(wounds_data and wounds_data[base.nickname] or 0))
    end
end

-- ============================================================
-- FUNZIONE: lionheart_debugAttachments()
-- Elenca ricorsivamente i child via getAttachments()
-- ============================================================
function lionheart_debugAttachments(player)

    local selected = lionheart_getSelectedObjects(player)
    if not selected or #selected < 1 then
        printToColor("[DEBUG] Seleziona un oggetto", player and player.color or "White", {r=1,g=0.6,b=0})
        return false
    end

    local function dump(obj, depth)
        local prefix = string.rep("  ", depth)
        print(prefix .. "- " .. tostring(obj.getName()) .. " guid=" .. tostring(obj.guid))

        local attachments = obj.getAttachments and obj.getAttachments() or {}
        print(prefix .. "  children count: " .. tostring(#attachments))

        for _, attData in ipairs(attachments) do
            -- attData potrebbe essere l'oggetto stesso o avere un campo guid
            local guid = type(attData) == "table" and attData.guid or (attData.guid)

            print(prefix .. "  RAW: " .. JSON.encode(attData))

            local childObj = getObjectFromGUID(guid)
            if childObj then
                dump(childObj, depth + 1)
            else
                print(prefix .. "  [child non risolvibile] guid=" .. tostring(guid))
            end
        end
    end
    
    for _, obj in ipairs(selected) do
        print("=== ATTACHMENTS: " .. tostring(obj.getName()) .. " ===")
        dump(obj, 0)
    end

    return true
end
-- ============================================================
-- FUNZIONE: lionheart_debugAttachments()
-- Elenca ricorsivamente i child via getAttachments()
-- ============================================================
function lionheart_debugAttachmentsJson(player)
    
    local selected = lionheart_getSelectedObjects(player)
    if not selected or #selected < 1 then
        printToColor("[DEBUG] Seleziona un oggetto", player and player.color or "White", {r=1,g=0.6,b=0})
        return false
    end

    local function dumpJSON(obj, depth)
        local prefix = string.rep("    ", depth)
        local co = obj.getCustomObject and obj.getCustomObject() or {}

        print(prefix .. '"customMesh": {')
        print(prefix .. '    "meshURL": "' .. tostring(co.mesh or "") .. '",')
        print(prefix .. '    "diffuseURL": "' .. tostring(co.diffuse or "") .. '",')
        print(prefix .. '    "colliderURL": "' .. tostring(co.collider or "") .. '",')
        print(prefix .. '    "material": ' .. tostring(co.material or 3) .. ',')
        print(prefix .. '    "type": ' .. tostring(co.type or 0))
        print(prefix .. '}')

        local children = obj.getAttachments and obj.getAttachments() or nil
        if children and #children > 0 then
            print(prefix .. ',"children": [')
            for i, child in ipairs(children) do
                print(prefix .. '  {')
                dumpJSON(child, depth + 2)
                print(prefix .. '  }' .. (i < #children and ',' or ''))
            end
            print(prefix .. ']')
        end
    end

    for _, obj in ipairs(selected) do
        print("// === " .. tostring(obj.getName()) .. " ===")
        print("{")
        dumpJSON(obj, 1)
        print("}")
    end

    return true
end
end)
