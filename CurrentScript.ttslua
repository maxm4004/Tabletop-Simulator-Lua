__bundle_register("rulesets.lionheart.loader", function(require, _LOADED, __bundle_register, __bundle_modules)
require("rulesets.lionheart.deployment.loader")

require("rulesets.lionheart.ui")
require("rulesets.lionheart.conditions")
require("rulesets.lionheart.callbacks")
require("rulesets.lionheart.phase_hooks")
require("rulesets.lionheart.lib")
require("rulesets.lionheart.phases")
require("rulesets.lionheart.persistence")
require("rulesets.lionheart.register")

ENGINE = ENGINE or {}
ENGINE.handlers = ENGINE.handlers or {}

-- FIX: auto-register filtrato.
-- La versione precedente registrava ogni funzione di _G, inclusi
-- built-in Lua (pairs, tostring, type, ecc.) e funzioni TTS API.
-- Ora vengono registrate solo le funzioni che soddisfano almeno
-- uno dei criteri: nome con underscore (pattern handler/callback),
-- oppure già presenti in ENGINE.handlers dal register esplicito.
-- I built-in non hanno underscore e non sono pre-registrati.
local builtins = {}
do
    -- Snapshot dei nomi built-in prima del ruleset load
    -- (in TTS il _G al momento del loader contiene solo i built-in
    --  più le funzioni engine già caricate)
    local knownBuiltins = {
        "pairs", "ipairs", "next", "select", "type", "tostring", "tonumber",
        "rawget", "rawset", "rawequal", "rawlen", "setmetatable", "getmetatable",
        "pcall", "xpcall", "error", "assert", "print", "unpack", "table",
        "string", "math", "os", "io", "coroutine", "package", "require",
        "load", "loadfile", "dofile", "collectgarbage", "gcinfo"
    }
    for _, name in ipairs(knownBuiltins) do
        builtins[name] = true
    end
end

for k, v in pairs(_G) do
    if type(v) == "function"
    and not builtins[k]
    and not ENGINE.handlers[k] then
        -- Registra solo funzioni del ruleset non già registrate esplicitamente
         ENGINE.handlers[k] = v
    end
end

end)
