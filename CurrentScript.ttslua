__bundle_register("engine.renderers", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- RENDERER BUILT-IN
-- Questi renderer sono disponibili per qualsiasi ruleset.
-- I ruleset possono aggiungere renderer custom tramite:
--   registerRenderer("nomeLayout", function(phase) ... end)
-- ============================================================
RENDERERS = {}

-- ============================================================
-- RENDERER: 1BtnClick
-- Mostra solo BTN_SINGLE (panelBtnDown).
-- ============================================================
RENDERERS["1BtnClick"] = function(phase)

    UI.setAttribute("panelBtnUp",   "active", "false")
    UI.setAttribute("panelBtnDown", "active", "true")
    UI.setAttribute("panelBtnDown", "offsetXY", "0 -192")
    UI.setAttribute("BTN_SINGLE",   "active", "true")
    UI.setAttribute("panelDices",   "active", "false")

end
-- ============================================================
-- RENDERER: 2BtnClick
-- Mostra BTN_ARMY1 e BTN_ARMY2 (panelBtnUp).
-- ============================================================
RENDERERS["2BtnClick"] = function(phase)

    UI.setAttribute("panelBtnUp",   "active", "true")
    UI.setAttribute("panelBtnDown", "active", "false")
    UI.setAttribute("panelBtnUp",   "offsetXY", "0 -192")
    UI.setAttribute("panelDices",   "active", "false")

end
-- ============================================================
-- RENDERER: 2BtnClickAndRoll
-- Mostra BTN_ARMY1, BTN_ARMY2 e il panel dadi.
-- ============================================================
RENDERERS["2BtnClickAndRoll"] = function(phase)

    UI.setAttribute("panelBtnUp",   "active", "true")
    UI.setAttribute("panelBtnUp",   "offsetXY", "0 -192")
    UI.setAttribute("panelBtnDown", "active", "false")
    UI.setAttribute("panelDices",   "active", "true")
    UI.setAttribute("panelDices",   "offsetXY", "0 -244")

end
-- ============================================================
-- RENDERER: 3BtnClick
-- Mostra BTN_ARMY1 e BTN_ARMY2 finché entrambi non hanno
-- confermato, poi switcha a BTN_SINGLE.
--
-- AGGIORNATO: legge ENGINE.state.Army1Done / Army2Done
-- (slot normalizzati) invece di TURN.completed (stato ruleset).
-- Questo rende il renderer indipendente dal ruleset attivo.
--
-- Compatibilità: i ruleset che popolano TURN.completed nei
-- propri callbacks non devono cambiare nulla — engine_execute
-- ora aggiorna ENGINE.state in parallelo, trasparentemente.
-- ============================================================
RENDERERS["3BtnClick"] = function(phase)

    UI.setAttribute("panelBtnUp",   "active", "true")
    UI.setAttribute("panelBtnUp",   "offsetXY", "0 -192")
    UI.setAttribute("panelBtnDown", "active", "false")
    UI.setAttribute("panelDices",   "active", "false")

    -- AGGIORNATO: ENGINE.state invece di TURN.completed
    local bothDone = ENGINE.state
                  and ENGINE.state.Army1Done
                  and ENGINE.state.Army2Done

    if bothDone then
        UI.setAttribute("panelBtnUp",   "active", "false")
        UI.setAttribute("panelBtnDown", "active", "true")
        UI.setAttribute("panelBtnDown", "offsetXY", "0 -192")
        UI.setAttribute("BTN_SINGLE",   "active", "true")
    end

end

end)
__bundle_register("engine.conditions", function(require, _LOADED, __bundle_register, __bundle_modules)
function checkConditions(conditions, action)

    if DEBUG then print("checkConditions") end

    if not conditions then
        return true
    end

    if type(conditions) == "string" then
        return checkCondition(conditions, action)
    end

    for i = 1, #conditions do
        if not checkCondition(conditions[i], action) then
            return false
        end
    end

    return true
end

function checkCondition(cond, action)
    local result = callCondition(cond, action)
    if DEBUG then print("Condition: "..cond.." ".. tostring(result)) end
    return result
end
end)
__bundle_register("engine.input", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- FUNZIONE: engine_handleButton()
-- ============================================================
function engine_handleButton(slot, player, value, id)

    if DEBUG then print("engine_handleButton") end

    local phase = ENGINE.phases[ENGINE.phase]
    if not phase or not phase.buttons then return end

    local button = phase.buttons[slot]
    if not button then return end

    if phase.enforceOwnership then
        local ok = callHandler("canUseButton", slot, player, value, id, button, phase)
        if ok == false then
            return
        end
    end

    local allowed = true

    if button.callback then
        local result = callHandler(button.callback, player, value, id, button)

        if result == false then
            allowed = false
        end
    end

    if not allowed then
        return
    end

    if button.action then
        engine_handleAction({
            type = button.action,
            player = player
        })
    end

    --callHandler("updateCenterPanel")
    --callHandler("aggiornaLinee")
end
-- ============================================================
-- FUNZIONE: onBtnArmy1()
-- ============================================================
function onBtnArmy1(player, value, id)
    engine_handleButton("BTN_ARMY1", player, value, id)
end

-- ============================================================
-- FUNZIONE: onBtnArmy2()
-- ============================================================
function onBtnArmy2(player, value, id)
    engine_handleButton("BTN_ARMY2", player, value, id)
end

-- ============================================================
-- FUNZIONE: onBtnScelta()
-- ============================================================
function onBtnScelta(player, value, id)
    engine_handleButton("BTN_SINGLE", player, value, id)
end
end)
__bundle_register("engine.ui", function(require, _LOADED, __bundle_register, __bundle_modules)
local MAX_UNIT_CARDS = 25

-- ============================================================
-- FUNZIONE: getEngineUiXml()
-- ============================================================
function getEngineUiXml()

    engine_buttonBarInit()

    local buttons = ""
    local positions = {
        {x=-281, y=10.5}, {x=-167, y=10.5}, {x=-57, y=10.5},
        {x=55,   y=10.5}, {x=166,  y=10.5}, {x=280, y=10.5},
        {x=-281, y=-40.5},{x=-167, y=-40.5},{x=-57, y=-40.5},
        {x=55,   y=-40.5},{x=166,  y=-40.5},{x=280, y=-40.5},
    }
    local widths = {110,100,102,102,100,110,110,100,102,102,100,110}

    for i = 1, ENGINE_BUTTONBAR.slotCount do
        local slot    = ENGINE_BUTTONBAR.slots[i]
        local id      = engine_buttonBarSlotId(i)
        local pos     = positions[i]
        local w       = widths[i]
        local label   = slot and slot.label    or ""
        local color   = slot and slot.color    or "rgba(0.15,0.15,0.15,1)"
        local tcol    = slot and slot.textColor or "White"
        local active  = (slot and slot.visible) and "true" or "false"
        local onclick = slot and slot.onClick  or "engine_buttonBarClick"
        local icon    = slot and slot.icon     or ""
        local iconW   = slot and slot.iconWidth  or 32
        local iconH   = slot and slot.iconHeight or 32

        buttons = buttons .. string.format(
            '<Button id="%s" icon="%s" iconWidth="%d" iconHeight="%d" text="%s" fontSize="13" width="%d" height="41" ' ..
            'position="%d %g 0" color="%s" textColor="%s" active="%s" ' ..
            'onClick="%s" image="Sprites/Layout/Button" ' ..
            'outline="#3A2A1AFF" outlineSize="1"/>\n',
            id, icon, iconW, iconH, label, w, pos.x, pos.y, color, tcol, active, onclick
        )
    end

    local cards = ""
    for i = 1, MAX_UNIT_CARDS do
        cards = cards .. string.format(
            '<Panel id="unit_card_%d" width="280" height="60" ' ..
            'color="rgba(0,0,0,0.7)" active="false" ' ..
            'onClick="onUnitCardClick" onClickArg="%d">' ..
            '<VerticalLayout padding="4 4 4 4" spacing="2">' ..
                '<Text id="unit_card_tipo_%d" text="" fontSize="9" fontStyle="Bold" ' ..
                'color="White" alignment="MiddleCenter"/>' ..
                '<Text id="unit_card_fig_%d" text="" fontSize="9" ' ..
                'color="rgba(200,200,200,1)" alignment="MiddleCenter"/>' ..
                '<Panel id="unit_card_bar_%d" height="6" width="70" color="#1B5E20FF"/>' ..
            '</VerticalLayout>' ..
            '</Panel>\n',
            i, i, i, i, i
        )
    end

    local panels = [[
        <Panel id="logo_panel" rectAlignment="UpperCenter" width="550" height="250" offsetXY="-700 0">
            <Image image="https://raw.githubusercontent.com/maxm4004/Tabletop-Simulator-Lua/refs/heads/main/logo/warforge01.png" preserveAspect="1"/>
        </Panel>
        <Panel id="warning" rectAlignment="LowerCenter" width="600" height="30" color="rgba(0,0,0,0.0)" offsetXY="0 700">
            <Text id="textWarning" text="" fontSize="26" fontStyle="Bold" color="rgba(212,175,55,0.9)" outline="#000000" outlineSize="2" alignment="MiddleCenter"/>
        </Panel>
        <Panel id="warforgeBar" position="0 -440 0">
            <Image id="warforgeBarBg" image="https://raw.githubusercontent.com/maxm4004/Tabletop-Simulator-Lua/refs/heads/main/images/bbar02.png" height="500" preserveAspect="true"/>
        ]] .. buttons .. [[
        </Panel>

        <!-- Schede unità -->
        
        <Panel id="unit_cards_panel" rectAlignment="LowerCenter" width="700" height="70" offsetXY="-80 150"
               active="false">  
               <HorizontalLayout id="unit_cards_layout" spacing="4" padding="4 4 4 4">
               ]] .. cards .. [[
                </HorizontalLayout>
        </Panel>
      
        <!-- Pannello modale dettaglio unità -->
        <!-- 
        <Panel id="unit_detail_overlay"
               rectAlignment="MiddleCenter"
               width="1920" height="1080"
               color="rgba(0,0,0,0.6)"
               active="false"
               onClick="onUnitDetailClose">
            <Panel id="unit_detail_panel"
                   rectAlignment="MiddleCenter"
                   width="400" height="300"
                   color="rgba(15,15,15,0.97)">
                <VerticalLayout padding="16 16 16 16" spacing="8">
                    <Text id="unit_detail_title"  text="" fontSize="18" fontStyle="Bold" color="rgba(220,170,50,1)" alignment="MiddleCenter"/>
                    <Text id="unit_detail_tipo"   text="" fontSize="13" color="White"/>
                    <Text id="unit_detail_basi"   text="" fontSize="13" color="White"/>
                    <Text id="unit_detail_figure" text="" fontSize="13" color="White"/>
                    <Text id="unit_detail_arma"   text="" fontSize="13" color="White"/>
                    <Text id="unit_detail_morale" text="" fontSize="13" color="White"/>
                    <Text id="unit_detail_valore" text="" fontSize="13" color="White"/>
                    <Button text="X CHIUDI" fontSize="12"
                            color="rgba(0.6,0.1,0.1,1)" textColor="White"
                            width="120" height="30"
                            onClick="onUnitDetailClose"/>
                </VerticalLayout>
            </Panel>
        </Panel>  
        -->
    ]]

    return panels
end

-- ============================================================
-- FUNZIONE: buildUI()
-- ============================================================
function buildUI()
    local enginePanels = getEngineUiXml()
    local rulesetXml   = callHandler("getRulesetUiXml") or ""
    local header = [[<XmlLayout>]]
    local bottom = "</XmlLayout>"
    local xml = header .. rulesetXml .. enginePanels .. bottom      
    UI.setXml(xml)
end

-- ============================================================
-- FUNZIONE: aggiornaSchedeUnita()
-- Popola le 10 card placeholder con i dati delle unità
-- Solo UI.setAttribute — nessun setXmlTable
-- ============================================================
function aggiornaSchedeUnita()

    -- Nascondi tutte le card
    for i = 1, MAX_UNIT_CARDS do
        UI.setAttribute("unit_card_" .. i, "active", "false")
        UI.setAttribute("unit_card_" .. i, "text",   "")
        UI.setAttribute("unit_card_" .. i, "onClickArg", tostring(i))
    end

    -- Raccoglie tutte le unità attive da entrambi gli eserciti
    local unita_attive = {}
    for slot = 1, 2 do
        local esercito = DEPLOYMENT.scanned[slot]
        if esercito then
            for _, unita in ipairs(esercito) do
                local basi_p = lionheart_basiPresentiUnita(unita)
                if basi_p > 0 then
                    table.insert(unita_attive, { unita=unita, slot=slot })
                end
            end
        end
    end

    if #unita_attive == 0 then
        UI.setAttribute("unit_cards_panel", "active", "false")
        return
    end

    -- Popola le card disponibili
    local n = math.min(#unita_attive, MAX_UNIT_CARDS)
    for i = 1, n do
        local entry   = unita_attive[i]
        local unita   = entry.unita
        print("[SCHEDE] card " .. i .. " -> " .. unita.tipo .. "_" .. unita.unita_num)
        local slot    = entry.slot
        local fpb     = (LIONHEART_DATA.unitTypes[unita.tipo] or {}).fpb or 1
        local fig_att = lionheart_figureTotaliUnita(unita)
        local fig_max = (unita.basi_max or #unita.basi) * fpb
        local perc    = fig_max > 0 and (fig_att / fig_max) or 0

        local col
        if perc > 0.6     then col = slot == 1 and "#1B5E20FF" or "#0D47A1FF"
        elseif perc > 0.3 then col = "#E65100FF"
        else                    col = "#B71C1CFF" end

        local nome = unita.tipo .. "_" .. unita.unita_num
        local label = nome .. "\n" .. fig_att .. "/" .. fig_max

        UI.setAttribute("unit_card_"      .. i, "active", "true")
        UI.setAttribute("unit_card_tipo_" .. i, "text",   unita.tipo .. "_" .. unita.unita_num)
        UI.setAttribute("unit_card_fig_"  .. i, "text",   fig_att .. "/" .. fig_max)
        -- barra salute colorata
        UI.setAttribute("unit_card_bar_"  .. i, "color",  col)

    end

    print("[SCHEDE] unit_cards_panel attivato, n=" .. tostring(n))
    UI.setAttribute("unit_cards_panel", "active", "true")
end

-- ============================================================
-- FUNZIONE: lionheart_basiPresentiUnita(unita)
-- ============================================================
function lionheart_basiPresentiUnita(unita)
    local count = 0
    for _, base in ipairs(unita.basi) do
        local obj = getObjectFromGUID(base.guid)
        if obj then count = count + 1 end
    end
    return count
end

-- ============================================================
-- FUNZIONE: lionheart_figureTotaliUnita(unita)
-- ============================================================
function lionheart_figureTotaliUnita(unita)
    local fpb    = (LIONHEART_DATA.unitTypes[unita.tipo] or {}).fpb or 0
    local figure = 0
    for _, base in ipairs(unita.basi) do
        local wounds = wounds_data and wounds_data[base.nickname] or 0
        figure = figure + math.max(0, fpb - wounds)
    end
    return figure
end

-- ============================================================
-- FUNZIONE: onUnitCardClick
-- ============================================================
function onUnitCardClick(player, value, id)
    local nome, slot_str = string.match(tostring(value), "^(.+)|(%d+)$")
    local slot = tonumber(slot_str)
    if not slot or not nome then return end

    local esercito = DEPLOYMENT.scanned[slot]
    if not esercito then return end

    for _, unita in ipairs(esercito) do
        local n = unita.tipo .. "_" .. unita.unita_num
        if n == nome then
            apriDettaglioUnita(unita, slot)
            return
        end
    end
end

-- ============================================================
-- FUNZIONE: apriDettaglioUnita(unita, slot)
-- ============================================================
function apriDettaglioUnita(unita, slot)
    local fpb     = (LIONHEART_DATA.unitTypes[unita.tipo] or {}).fpb or 1
    local fig_att = lionheart_figureTotaliUnita(unita)
    local fig_max = (unita.basi_max or #unita.basi) * fpb
    local basi_p  = lionheart_basiPresentiUnita(unita)
    local perc    = fig_max > 0 and (fig_att / fig_max) or 0

    local salute
    if perc > 0.6     then salute = "BUONA"
    elseif perc > 0.3 then salute = "CRITICA"
    else                    salute = "GRAVE" end

    local val_str = (unita.valore == "S" or unita.valore == 1)  and "Superiore" or
                    (unita.valore == "I" or unita.valore == -1) and "Inferiore"  or "Normale"

    UI.setAttribute("unit_detail_title",  "text", unita.nome_display or (unita.tipo.."_"..unita.unita_num))
    UI.setAttribute("unit_detail_tipo",   "text", "Tipo: "    .. unita.tipo)
    UI.setAttribute("unit_detail_basi",   "text", "Basi: "    .. basi_p .. "/" .. (unita.basi_max or #unita.basi))
    UI.setAttribute("unit_detail_figure", "text", "Figure: "  .. fig_att .. "/" .. fig_max)
    UI.setAttribute("unit_detail_arma",   "text", "Arma: "    .. (unita.arma or "---"))
    UI.setAttribute("unit_detail_morale", "text", "Salute: "  .. salute)
    UI.setAttribute("unit_detail_valore", "text", "Qualita: " .. val_str)
    UI.setAttribute("unit_detail_overlay","active", "true")
end

-- ============================================================
-- FUNZIONE: onUnitDetailClose
-- ============================================================
function onUnitDetailClose(player, value, id)
    UI.setAttribute("unit_detail_overlay", "active", "false")
end

end)
