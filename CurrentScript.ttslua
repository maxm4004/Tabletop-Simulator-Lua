-- ============================================================
function roll_btn_all(player, value, id)

    if id == BUTTONS.BTN_ARMY1 then
        if DICE_CONTEST.rolledNumberArmy1 ~= nil then return false end

        spinDie("diceArmy1", 1, function(finalValue)
            DICE_CONTEST.rolledNumberArmy1 = finalValue
            callHandler("dice_check")
            if DICE_CONTEST.winner ~= nil then
                callHandler("engine_transition")
            end
            callHandler("updateCenterPanel")
        end)
    end

    if id == BUTTONS.BTN_ARMY2 then
        if DICE_CONTEST.rolledNumberArmy2 ~= nil then return false end

        spinDie("diceArmy2", 2, function(finalValue)
            DICE_CONTEST.rolledNumberArmy2 = finalValue
            callHandler("dice_check")
            if DICE_CONTEST.winner ~= nil then
                callHandler("engine_transition")
            end
            callHandler("updateCenterPanel")
        end)
    end

    return false
end
-- ============================================================
-- FUNZIONE: assign_initiative_btn_all()
-- ============================================================
function assign_initiative_btn_all(player, value, id)

    local winner = ARMY[DICE_CONTEST.winner]
    local clicker = ARMY[getArmyByColor(player)]
    local clicked = ARMY[getArmyByButton(id)]
    
    if clicker.name ~= winner.name then
        fadeOut(clicker.name.." can't assign anything")
    else 
        DICE_CONTEST.initiative = clicked
        callHandler("resetTurnForPhase")
        local army = callHandler("getArmySlotByColor", clicked.color)

        TURN.firstArmy = army
        TURN.activeArmy = army

        TURN.completed.Army1 = false
        TURN.completed.Army2 = false
        fadeOut("Initiative assigned to "..clicked.name) 
    end
end
-- ============================================================
-- FUNZIONE: lionheart_getSelectedObjects()
-- ============================================================
function lionheart_getSelectedObjects()
    for _, color in ipairs(getSeatedPlayers()) do
        local selected = Player[color].getSelectedObjects()
        if selected ~= nil and #selected > 0 then return selected end
    end

    local fallback = {"White", "Red", "Blue", "Green", "Yellow", "Orange", "Purple", "Pink", "Brown", "Teal", "Black"}
    for _, color in ipairs(fallback) do
        if Player[color] ~= nil then
            local selected = Player[color].getSelectedObjects()
            if selected ~= nil and #selected > 0 then return selected end
        end
    end

    return {}
end
-- ============================================================
-- FUNZIONE: lionheart_showRange()
-- ============================================================
function lionheart_showRange(player, value, id, buttonConfig)
    local selected = lionheart_getSelectedObjects()
    if selected == nil or #selected < 1 then
        printToAll("[TIRO] Seleziona una base", {r=1,g=0.6,b=0})
        return false
    end

    local shooter = selected[1]
    local pos = shooter.getPosition()
    local fwd = shooter.getTransformForward()
    local dir = Vector(fwd.x, 0, fwd.z):normalized()
    local angle = math.rad(LIONHEART_SHOOTING.angle)
    local points = {}

    for i = 0, 30 do
        local t = i / 30
        local a = -angle + (2 * angle * t)
        local d = Vector(dir.x * math.cos(a) - dir.z * math.sin(a), 0, dir.x * math.sin(a) + dir.z * math.cos(a))
        local p = Vector(pos.x + d.x * LIONHEART_SHOOTING.range, pos.y + 0.1, pos.z + d.z * LIONHEART_SHOOTING.range)
        table.insert(points, shooter.positionToLocal(p))
    end

    shooter.setVectorLines({{points = points, color = {1, 0.8, 0.1}, thickness = 0.1}})
    LIONHEART_SHOOTING.activeShooter = shooter

    Wait.time(function()
        if shooter ~= nil then shooter.setVectorLines({}) end
    end, 10)

    return true
end
-- ============================================================
-- FUNZIONE: lionheart_fire()
-- ============================================================
function lionheart_fire(player, value, id, buttonConfig)
    local selected = lionheart_getSelectedObjects()
    if selected == nil or #selected < 1 then
        printToAll("[TIRO] Seleziona una base", {r=1,g=0.6,b=0})
        return false
    end

    local shooter = selected[1]
    if LIONHEART_SHOOTING.activeAnimation ~= nil then LIONHEART_SHOOTING.activeAnimation.active = false end

    local enemyTag = "Army1"
    if shooter.hasTag ~= nil and shooter.hasTag("Army1") then enemyTag = "Army2" end

    local target = nil
    local bestDist = 999999
    for _, obj in ipairs(getAllObjects()) do
        if obj ~= shooter and obj.hasTag ~= nil and obj.hasTag(enemyTag) then
            local dist = (obj.getPosition() - shooter.getPosition()):magnitude()
            if dist < bestDist then
                bestDist = dist
                target = obj
            end
        end
    end

    if target == nil then
        printToAll("[TIRO] Nessun target", {r=1,g=0.6,b=0})
        return false
    end

    if LIONHEART_SHOOTING.activeTarget ~= nil then LIONHEART_SHOOTING.activeTarget.highlightOff() end
    target.highlightOn({1,0.1,0.1}, 10)

    LIONHEART_SHOOTING.activeTarget = target
    LIONHEART_SHOOTING.activeShooter = shooter

    local state = { active = true }
    LIONHEART_SHOOTING.activeAnimation = state

    local function loop()
        if not state.active then
            if shooter ~= nil then shooter.setVectorLines({}) end
            return
        end
        if shooter == nil or target == nil then return end

        shooter.setVectorLines({{points = {shooter.positionToLocal(shooter.getPosition()), shooter.positionToLocal(target.getPosition())}, color = {1, 0.8, 0.1}, thickness = 0.25}})
        Wait.frames(loop, 5)
    end

    loop()
    return true
end
-- ============================================================
-- FUNZIONE: lionheart_stopFire()
-- ============================================================
function lionheart_stopFire(player, value, id, buttonConfig)
    if LIONHEART_SHOOTING.activeAnimation ~= nil then LIONHEART_SHOOTING.activeAnimation.active = false end
    if LIONHEART_SHOOTING.activeShooter ~= nil then LIONHEART_SHOOTING.activeShooter.setVectorLines({}) end
    if LIONHEART_SHOOTING.activeTarget ~= nil then LIONHEART_SHOOTING.activeTarget.highlightOff() end

    LIONHEART_SHOOTING.activeAnimation = nil
    LIONHEART_SHOOTING.activeShooter = nil
    LIONHEART_SHOOTING.activeTarget = nil
    return true
end
-- ============================================================
-- FUNZIONE: lionheart_lineLeft()
-- ============================================================
function lionheart_lineLeft(player, value, id, buttonConfig) return lionheart_applyFormation("lineLeft") end
-- ============================================================
-- FUNZIONE: lionheart_lineRight()
-- ============================================================
function lionheart_lineRight(player, value, id, buttonConfig) return lionheart_applyFormation("lineRight") end
-- ============================================================
-- FUNZIONE: lionheart_columnUp()
-- ============================================================
function lionheart_columnUp(player, value, id, buttonConfig) return lionheart_applyFormation("columnUp") end
-- ============================================================
-- FUNZIONE: lionheart_columnDown()
-- ============================================================
function lionheart_columnDown(player, value, id, buttonConfig) return lionheart_applyFormation("columnDown") end
-- ============================================================
-- FUNZIONE: lionheart_applyFormation()
-- ============================================================
function lionheart_applyFormation(mode)
    local selected = lionheart_getSelectedObjects()
    if selected == nil or #selected < 2 then
        printToAll("[FORMAZIONE] Seleziona almeno 2 basi", {r=1,g=0.6,b=0})
        return false
    end

    local leader = selected[1]
    local right = leader.getTransformRight()
    local forward = leader.getTransformForward()

    for i = 2, #selected do
        local obj = selected[i]
        local index = i - 1
        local pos = nil

        if mode == "lineLeft" then
            pos = leader.getPosition() - right * (LIONHEART_FORMATION.horizontalSpacing * index)
        elseif mode == "lineRight" then
            pos = leader.getPosition() + right * (LIONHEART_FORMATION.horizontalSpacing * index)
        elseif mode == "columnUp" then
            pos = leader.getPosition() + forward * (LIONHEART_FORMATION.verticalSpacing * index)
        elseif mode == "columnDown" then
            pos = leader.getPosition() - forward * (LIONHEART_FORMATION.verticalSpacing * index)
        end

        if pos ~= nil then
            obj.setPosition(pos)
            obj.setRotation(leader.getRotation())
        end
    end

    return true
end
end)
__bundle_register("rulesets.lionheart.conditions", function(require, _LOADED, __bundle_register, __bundle_modules)
function registerDefaultConditions()

    registerCondition(COND.REQUIREMENT_MET, function(action)
        return colorArmy1 == COLOR.ARMY1 and colorArmy2 == COLOR.ARMY2
    end)

    registerCondition(COND.BOTH_PLAYERS_SELECTED, function(action)
        return TURN and TURN.completed and TURN.completed.Army1 and TURN.completed.Army2
    end)

    registerCondition(COND.CONFIRM_READY, function(action)
        return action and action.type and action.type == ACTION.CONFIRM and TURN and TURN.completed and TURN.completed.Army1 and TURN.completed.Army2
    end)

    registerCondition(COND.CONFIRM_IMMEDIATE, function(action)
        return action and action.type == ACTION.CONFIRM
    end)

    registerCondition(COND.WINNER, function(action)
        return DICE_CONTEST and DICE_CONTEST.winner ~= nil
    end)

    registerCondition(COND.ASSIGNMENT, function(action)
        return DICE_CONTEST and DICE_CONTEST.initiative ~= nil
    end)

    registerCondition(COND.AUTO_ADVANCE, function(action)
        return true
    end)
end
end)
