__bundle_register("engine.buttonbar.config", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- WARFORGE ENGINE / BUTTONBAR CONFIG
-- L'engine riceve SOLO testo JSON gia' scaricato.
-- NON conosce URL, GitHub o ruleset.
-- ============================================================

function engine_buttonBarLoadJson(jsonText)

    engine_buttonBarInit()

    if jsonText == nil or jsonText == "" then
        printToAll("[BUTTONBAR] JSON vuoto", {r=1,g=0.3,b=0.3})
        return false
    end

    local ok, data = pcall(JSON.decode, jsonText)

    if not ok or type(data) ~= "table" then
        printToAll("[BUTTONBAR] JSON non valido", {r=1,g=0.3,b=0.3})
        return false
    end

    local slots = data.buttonbar and data.buttonbar.slots or data.slots or {}

    for i = 1, ENGINE_BUTTONBAR.slotCount do
        
        local cfg = slots[tostring(i)] or slots[i]

        if cfg ~= nil then
            ENGINE_BUTTONBAR.slots[i] = {
                label = cfg.label or "",
                class = cfg.class,
                callBack = cfg.callBack,
                tooltip = cfg.tooltip or "",
                visible = cfg.visible ~= false,
                enabled = cfg.enabled ~= false,
                colors = cfg.colors,
                textColor = cfg.textColor or "Black"
            }
        else
            ENGINE_BUTTONBAR.slots[i] = engine_buttonBarEmptySlot()
        end
    end

    engine_buttonBarRender()
    return true
end

end)
__bundle_register("engine.buttonbar.state", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- WARFORGE ENGINE / BUTTONBAR STATE
-- 12 slot neutri. Nessun riferimento a ruleset o URL remoti.
-- ============================================================

ENGINE_BUTTONBAR = ENGINE_BUTTONBAR or {
    initialized = false,
    slots = {},
    slotCount = 9,
    xmlPrefix = "WF_BAR_"
}

function engine_buttonBarEmptySlot()
    return {
        label = "",
        onClick = nil,
        tooltip = "",
        visible = false,
        enabled = false,
        color = "rgba(0.15,0.15,0.15,1)",
        textColor = "White"
    }
end

function engine_buttonBarInit()

    if DEBUG then print("engine_buttonBarInit") end

    if ENGINE_BUTTONBAR.initialized then
        return true
    end

    ENGINE_BUTTONBAR.slots = {}

    for i = 1, ENGINE_BUTTONBAR.slotCount do
        ENGINE_BUTTONBAR.slots[i] = engine_buttonBarEmptySlot()
    end

    ENGINE_BUTTONBAR.initialized = true
    return true
end

function engine_buttonBarSlotId(slot)
    return ENGINE_BUTTONBAR.xmlPrefix .. string.format("%02d", tonumber(slot))
end

function engine_buttonBarParseSlotFromId(id)
    if id == nil then return nil end

    local n = string.match(id, "(%d+)$")
    if n == nil then return nil end

    local slot = tonumber(n)
    if slot == nil then return nil end
    if slot < 1 or slot > ENGINE_BUTTONBAR.slotCount then return nil end

    return slot
end

end)
__bundle_register("engine.buttonbar.ui", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- WARFORGE ENGINE / BUTTONBAR UI
-- Aggiorna 12 Button XML esistenti: WF_BAR_01 ... WF_BAR_12
-- ============================================================

function engine_buttonBarRender()
 
    if UI == nil then
        return false
    end

    for i = 1, ENGINE_BUTTONBAR.slotCount do

        local slot = ENGINE_BUTTONBAR.slots[i]
        local id = engine_buttonBarSlotId(i)

        UI.setAttribute(id, "text", slot.label or "")
        UI.setAttribute(id, "tooltip", slot.tooltip or "")
        UI.setAttribute(id, "active", slot.visible and "true" or "false")
        UI.setAttribute(id, "interactable", slot.enabled and "true" or "false")
        UI.setAttribute(id, "colors", slot.colors)
        UI.setAttribute(id, "textColor", slot.textColor)

    end

    return true
end
end)
__bundle_register("engine.renderers", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- RENDERER BUILT-IN
-- Questi renderer sono disponibili per qualsiasi ruleset.
-- I ruleset possono aggiungere renderer custom tramite:
--   registerRenderer("nomeLayout", function(phase) ... end)
-- ============================================================
RENDERERS = {}

-- ============================================================
-- RENDERER: 1BtnClick
-- Mostra solo BTN_SINGLE (panelBtnDown).
-- ============================================================
RENDERERS["1BtnClick"] = function(phase)

    UI.setAttribute("panelBtnUp",   "active", "false")
    UI.setAttribute("panelBtnDown", "active", "true")
    UI.setAttribute("panelBtnDown", "offsetXY", "0 -192")
    UI.setAttribute("BTN_SINGLE",   "active", "true")
    UI.setAttribute("panelDices",   "active", "false")

end
-- ============================================================
-- RENDERER: 2BtnClick
-- Mostra BTN_ARMY1 e BTN_ARMY2 (panelBtnUp).
-- ============================================================
RENDERERS["2BtnClick"] = function(phase)

    UI.setAttribute("panelBtnUp",   "active", "true")
    UI.setAttribute("panelBtnDown", "active", "false")
    UI.setAttribute("panelBtnUp",   "offsetXY", "0 -192")
    UI.setAttribute("panelDices",   "active", "false")

end
-- ============================================================
-- RENDERER: 2BtnClickAndRoll
-- Mostra BTN_ARMY1, BTN_ARMY2 e il panel dadi.
-- ============================================================
RENDERERS["2BtnClickAndRoll"] = function(phase)

    UI.setAttribute("panelBtnUp",   "active", "true")
    UI.setAttribute("panelBtnUp",   "offsetXY", "0 -192")
    UI.setAttribute("panelBtnDown", "active", "false")
    UI.setAttribute("panelDices",   "active", "true")
    UI.setAttribute("panelDices",   "offsetXY", "0 -244")

end
-- ============================================================
-- RENDERER: 3BtnClick
-- Mostra BTN_ARMY1 e BTN_ARMY2 finché entrambi non hanno
-- confermato, poi switcha a BTN_SINGLE.
--
-- AGGIORNATO: legge ENGINE.state.Army1Done / Army2Done
-- (slot normalizzati) invece di TURN.completed (stato ruleset).
-- Questo rende il renderer indipendente dal ruleset attivo.
--
-- Compatibilità: i ruleset che popolano TURN.completed nei
-- propri callbacks non devono cambiare nulla — engine_execute
-- ora aggiorna ENGINE.state in parallelo, trasparentemente.
-- ============================================================
RENDERERS["3BtnClick"] = function(phase)

    UI.setAttribute("panelBtnUp",   "active", "true")
    UI.setAttribute("panelBtnUp",   "offsetXY", "0 -192")
    UI.setAttribute("panelBtnDown", "active", "false")
    UI.setAttribute("panelDices",   "active", "false")

    -- AGGIORNATO: ENGINE.state invece di TURN.completed
    local bothDone = ENGINE.state
                  and ENGINE.state.Army1Done
                  and ENGINE.state.Army2Done

    if bothDone then
        UI.setAttribute("panelBtnUp",   "active", "false")
        UI.setAttribute("panelBtnDown", "active", "true")
        UI.setAttribute("panelBtnDown", "offsetXY", "0 -192")
        UI.setAttribute("BTN_SINGLE",   "active", "true")
    end

end
-- ============================================================
-- RENDERER: 2BtnFireOrCancel
-- ============================================================
RENDERERS["2BtnFireOrCancel"] = function(phase)

    UI.setAttribute("panelBtnUp",   "active", "true")
    UI.setAttribute("panelBtnUp",   "offsetXY", "0 -192")
    UI.setAttribute("panelBtnDown", "active", "false")
    UI.setAttribute("panelDices",   "active", "true")
    UI.setAttribute("panelDices",   "offsetXY", "0 -244")

end
end)
__bundle_register("engine.conditions", function(require, _LOADED, __bundle_register, __bundle_modules)
function checkConditions(conditions, action)

    if DEBUG then print("checkConditions") end

    if not conditions then
        return true
    end

    if type(conditions) == "string" then
        return checkCondition(conditions, action)
    end

    for i = 1, #conditions do
        if not checkCondition(conditions[i], action) then
            return false
        end
    end

    return true
end

function checkCondition(cond, action)
    local result = callCondition(cond, action)
    if DEBUG then print("Condition: "..cond.." ".. tostring(result)) end
    return result
end
end)
__bundle_register("engine.input", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- FUNZIONE: engine_handleButton()
-- ============================================================
function engine_handleButton(slot, player, value, id)

    if DEBUG then print("engine_handleButton") end

    local phase = ENGINE.phases[ENGINE.phase]
    if not phase or not phase.buttons then return end

    local button = phase.buttons[slot]
    if not button then return end

    if phase.enforceOwnership then
        local ok = callHandler("canUseButton", slot, player, value, id, button, phase)
        if ok == false then
            return
        end
    end

    local allowed = true

    if button.callback then
        local result = callHandler(button.callback, player, value, id, button)

        if result == false then
            allowed = false
        end
    end

    if not allowed then
        return
    end

    if button.action then
        engine_handleAction({
            type = button.action,
            player = player
        })
    end

    --callHandler("updateCenterPanel")
    --callHandler("aggiornaLinee")
end
-- ============================================================
-- FUNZIONE: onBtnArmy1()
-- ============================================================
function onBtnArmy1(player, value, id)
    engine_handleButton("BTN_ARMY1", player, value, id)
end

-- ============================================================
-- FUNZIONE: onBtnArmy2()
-- ============================================================
function onBtnArmy2(player, value, id)
    engine_handleButton("BTN_ARMY2", player, value, id)
end

-- ============================================================
-- FUNZIONE: onBtnScelta()
-- ============================================================
function onBtnScelta(player, value, id)
    engine_handleButton("BTN_SINGLE", player, value, id)
end
end)
__bundle_register("engine.ui", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- engine/ui.ttslua
-- ============================================================

function getEngineUiXml()

    engine_buttonBarInit()

    local buttons = ""
    local positions = {
        {x=-192, y=275}, 
        {x=-192, y=222}, 
        {x=-192, y=169},
        {x=-192, y=116}, 
        {x=-192, y=63}, 
        {x=-192, y=10},
        {x=-192, y=-43},
        {x=-192, y=-96},
        {x=-192, y=-149},
        {x=-192, y=-202}
    }
    local widths  = {100,100,100,100,100,100,100,100,100,100}
    local heights = {45,45,45,45,45,45,45,45,45,45}

    for i = 1, ENGINE_BUTTONBAR.slotCount do
        local slot    = ENGINE_BUTTONBAR.slots[i]
        local id      = engine_buttonBarSlotId(i)
        local pos     = positions[i]
        local w       = widths[i]
        local h       = heights[i]
        local label   = slot and slot.label    or ""
        local colors   = slot and slot.colors    or "rgba(0.15,0.15,0.15,1)"
        local tcol    = slot and slot.textColor or "Orange"
        local active  = (slot and slot.visible) and "true" or "false"
        local onclick = slot and slot.onClick  or "engine_buttonBarClick"

        buttons = buttons .. string.format(
            '<Button id="%s" text="%s" font="warforge_font" fontSize="10" fontStyle="Bold" width="%d" height="%d" ' ..
            'position="%d %g 0" color="%s" textColor="%s" active="%s" ' ..
            'onClick="%s" image="Sprites/Layout/Button" ' ..
            'outline="#3A2A1AFF" outlineSize="1"/>\n',
            id, label:upper(), w, h, pos.x, pos.y, colors, tcol, active, onclick
        )
    end

    local panels = [[
        <Panel id="logo_panel" rectAlignment="UpperCenter" width="650" height="500" offsetXY="-700 80">
            <Image image="https://raw.githubusercontent.com/maxm4004/Tabletop-Simulator-Lua/refs/heads/main/logo/logo01.png" preserveAspect="1"/>
        </Panel>
        <Panel id="warning" rectAlignment="LowerCenter" width="600" height="30" color="rgba(0,0,0,0)" offsetXY="0 700">
            <Text id="textWarning" text="" fontSize="20" font="warforge_font" fontStyle="Bold" color="rgba(212,175,55,0.9)" outline="#000000" outlineSize="1" alignment="MiddleCenter"/>
        </Panel>
        <Panel rectAlignment="LowerCenter" width="600" height="30" color="rgba(0,0,0,0)" offsetXY="0 200">
            <Text id="playerGameMessage" text="" font="warforge_font" fontSize="13" color="rgba(212,175,55,0.9)" outline="#000000" outlineSize="1" alignment="MiddleCenter"/>
        </Panel>
        <Panel id="panelVersion"
            rectAlignment="UpperCenter"
            width="420"
            height="30"
            color="rgba(0,0,0,0.35)"
            offsetXY="-700 -320">
            <Text id="versione" text="" font="warforge_font" fontSize="13" color="Yellow" alignment="MiddleCenter" outline="#000000" outlineSize="1"/>
        </Panel> 
        <Panel id="warforgeBar" position="1098 0" rectAlignment="MiddleRight">
        ]] .. buttons .. [[
        </Panel>    
    ]]

    return panels
end

-- ============================================================
-- FUNZIONE: buildUI()
-- ============================================================
function buildUI()
    local enginePanels = getEngineUiXml()
    local rulesetXml   = callHandler("getRulesetUiXml") or ""
    local header = [[<XmlLayout xmlns="XmlLayout"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="XmlLayout ../../../Configuration/XmlLayout.xsd">]]
    local bottom = "</XmlLayout>"
    UI.setXml(header .. rulesetXml .. enginePanels .. bottom)
end
end)
__bundle_register("engine.core", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- FUNZIONE: engine_init()
-- ============================================================
function engine_init()

    if DEBUG then print("engine_init") end

    if not callHandler then
        printToAll("ERRORE: callHandler non caricato", "Red")
        return
    end

    if not ENGINE or not ENGINE.phases then
        printToAll("ERRORE: ENGINE.phases non inizializzato", "Red")
        return
    end

    if not ENGINE.phase then
        printToAll("ERRORE: ENGINE.phase non inizializzata", "Red")
        return
    end

    if not ENGINE.phases[ENGINE.phase] then
        printToAll("ERRORE: fase non trovata: " .. tostring(ENGINE.phase), "Red")
        return
    end

    callHandler("engine_validatePhases")
    callHandler("initUI")

    -- Aspetta che UI.setXml sia processato prima di renderizzare i pulsanti
    Wait.frames(function()
        engine_enterPhase(ENGINE.phase, nil)
    end, 30)
end
-- ============================================================
-- FUNZIONE: engine_validatePhases()
-- ============================================================
function engine_validatePhases()

    if not ENGINE.phases then
        error("ENGINE.phases NIL")
    end

    for phaseName, phaseData in pairs(ENGINE.phases) do

        if not phaseData.allowedActions then
            error("Manca allowedActions in fase: "..phaseName)
        end

        if not phaseData.transitions then
            error("Manca transitions in fase: "..phaseName)
        end

        if not phaseData.render then
            error("Manca render in fase: "..phaseName)
        end

        if phaseData.buttons then
            for slot, btn in pairs(phaseData.buttons) do
                if type(btn) ~= "table" then
                    error("Button malformato in fase: "..phaseName.." slot: "..slot)
                end
                if btn.action and type(btn.action) ~= "string" then
                    error("Button action non valida in fase: "..phaseName.." slot: "..slot)
                end
                if btn.label and type(btn.label) ~= "string" then
                    error("Button label non valida in fase: "..phaseName.." slot: "..slot)
                end
                if btn.textColor and type(btn.textColor) ~= "string" then
                    error("Button textColor non valida in fase: "..phaseName.." slot: "..slot)
                end
                if btn.callback and type(btn.callback) ~= "string" then
                    error("Button callback non valida in fase: "..phaseName.." slot: "..slot)
                end
            end
        end

        for i = 1, #phaseData.transitions do
            local t = phaseData.transitions[i]
            if not t.to then
                error("Transizione senza 'to' in fase: "..phaseName)
            end
            if not ENGINE.phases[t.to] then
                error("Transizione verso fase inesistente: "..t.to.." (da "..phaseName..")")
            end
            if not t.conditions then
                error("Transizione senza conditions in fase: "..phaseName)
            end
        end
    end
end
-- ============================================================
-- FUNZIONE: engine_handleAction()
-- ============================================================
function engine_handleAction(action)

    if DEBUG then print("engine_handleAction") end

    if not engine_isAllowed(action.type) then
        return
    end

    engine_execute(action)
    engine_transition(action)
    callHandler("updateCenterPanel")
end
-- ============================================================
-- FUNZIONE: engine_isAllowed()
-- ============================================================
function engine_isAllowed(actionType)

    if DEBUG then print("engine_isAllowed") end

    local phase = ENGINE.phases[ENGINE.phase]
    if not phase then return false end

    for i = 1, #phase.allowedActions do
        if actionType == phase.allowedActions[i] then
            return true
        end
    end

    return false
end
-- ============================================================
-- FUNZIONE: engine_execute()
-- RIPRISTINATA: aggiorna ENGINE.state con slot normalizzati.
--
-- ENGINE.state è lo stato che l'engine conosce — indipendente
-- dal ruleset. I renderer built-in leggono da qui.
-- I ruleset leggono il proprio stato (es. TURN.completed)
-- che aggiornano nei propri callbacks. I due sistemi coesistono
-- senza collisione.
--
-- Slot normalizzati ENGINE.state:
--   Army1Done   (bool) — qualcuno ha cliccato BTN_ARMY1
--   Army2Done   (bool) — qualcuno ha cliccato BTN_ARMY2
--   ConfirmDone (bool) — qualcuno ha cliccato BTN_SINGLE
--
-- Nota: nomi volutamente diversi da Army1Click/Army2Click
-- del legacy Global.-1.lua per evitare ambiguità.
-- ============================================================
function engine_execute(action)

    if DEBUG then print("engine_execute: " .. tostring(action and action.type)) end

    if not action or not action.type then return end

    ENGINE.state = ENGINE.state or {}

    if action.type == ACTION.ARMY1_CLICK then
        ENGINE.state.Army1Done = true

    elseif action.type == ACTION.ARMY2_CLICK then
        ENGINE.state.Army2Done = true

    elseif action.type == ACTION.CONFIRM then
        ENGINE.state.ConfirmDone = true
    end
end
-- ============================================================
-- FUNZIONE: engine_transition()
-- Fix precedente mantenuto: guardia anti-ciclo con visited.
-- ============================================================
function engine_transition(action)

    if DEBUG_CALLBACK then print("engine_transition") end

    local phase = ENGINE.phases[ENGINE.phase]
    if not phase then return end

    -- Prima passa: transizione guidata dall'action
    local transitioned = false

    if action then
        for i = 1, #phase.transitions do
            local t = phase.transitions[i]
            if checkConditions(t.conditions or {}, action) then
                local oldPhaseName = ENGINE.phase
                engine_exitPhase(oldPhaseName)
                ENGINE.phase = t.to
                engine_resetState()
                engine_enterPhase(ENGINE.phase, oldPhaseName)
                transitioned = true
                break
            end
        end
    end

    if transitioned then return end

    -- Seconda passa: auto-advance senza input
    -- Guardia anti-ciclo tramite tabella visited
    local visited = {}
    local changed = true

    while changed do
        changed = false

        if visited[ENGINE.phase] then
            if DEBUG then
                print("engine_transition: ciclo rilevato su fase " .. ENGINE.phase .. " — interrotto")
            end
            break
        end
        visited[ENGINE.phase] = true

        local currentPhase = ENGINE.phases[ENGINE.phase]
        if not currentPhase then return end

        for i = 1, #currentPhase.transitions do
            local t = currentPhase.transitions[i]

            if checkConditions(t.conditions or {}, nil) then
                local oldPhaseName = ENGINE.phase
                engine_exitPhase(oldPhaseName)
                ENGINE.phase = t.to
                engine_resetState()
                engine_enterPhase(ENGINE.phase, oldPhaseName)
                changed = true
                break
            end
        end
    end
end
-- ============================================================
-- FUNZIONE: engine_resetState()
-- Azzera sia i slot normalizzati engine che quelli legacy
-- ============================================================
function engine_resetState()

    if DEBUG then print("engine_resetState") end

    ENGINE.state = {
        -- Slot normalizzati (letti dai renderer built-in)
        Army1Done   = false,
        Army2Done   = false,
        ConfirmDone = false,
        -- Slot legacy mantenuti per compatibilità
        -- con condizioni che leggono Army1Click/Army2Click
        Army1Click   = false,
        Army2Click   = false,
        ConfirmClick = false,
    }
end
-- ============================================================
-- FUNZIONE: engine_enterPhase()
-- ============================================================
function engine_enterPhase(newPhaseName, oldPhaseName)

    if DEBUG_CALLBACK then print("engine_enterPhase: " .. tostring(newPhaseName)) end

    local phase = ENGINE.phases[newPhaseName]
    if not phase then return end

    if phase.before then
        callHandler(phase.before, newPhaseName, phase)
    end
end
-- ============================================================
-- FUNZIONE: engine_exitPhase()
-- ============================================================
function engine_exitPhase(oldPhaseName)

    if DEBUG_CALLBACK then print("engine_exitPhase: " .. tostring(oldPhaseName)) end

    local phase = ENGINE.phases[oldPhaseName]
    if not phase then return end

    if phase.after then
        callHandler(phase.after, oldPhaseName, phase)
    end
end
-- ============================================================
-- FUNZIONE: engine_buttonBarClick()
-- ============================================================
function engine_buttonBarClick(player, value, id)

    engine_buttonBarInit()

    local slotNumber = engine_buttonBarParseSlotFromId(id)

    if slotNumber == nil then
        printToAll("[BUTTONBAR] id bottone non valido: " .. tostring(id), {r=1,g=0.3,b=0.3})
        return false
    end

    local slot = ENGINE_BUTTONBAR.slots[slotNumber]

    if slot == nil then return false end
    if slot.enabled ~= true then return false end

    if slot.callBack == nil or slot.callBack == "" then
        printToAll("[BUTTONBAR] slot senza callBack: " .. tostring(slotNumber), {r=1,g=0.6,b=0})
        return false
    end

     return callHandler(slot.callBack, player, value, id, slot)
end
end)
__bundle_register("engine.boot", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- WARFORGE BOOT
-- ============================================================
function warforge_boot(rulesetName, save_state)
    if clear then clear() end
    if VERSION then printToAll(VERSION, "Yellow") end
    if DEBUG then print("warforge_boot") end

    engine_reset()
    math.randomseed(os.time())
    callHandler("rulesetInit", save_state)

    SAVE_STATE = save_state
end
-- ============================================================
-- autoRegisterFromPhases
-- ============================================================
function autoRegisterFromPhases()

    ENGINE = ENGINE or {}
    ENGINE.handlers = ENGINE.handlers or {}

    for phaseName, phase in pairs(ENGINE.phases or {}) do

        if phase.before and _G[phase.before] then
            ENGINE.handlers[phase.before] = _G[phase.before]
        end

        if phase.after and _G[phase.after] then
            ENGINE.handlers[phase.after] = _G[phase.after]
        end

        for slot, button in pairs(phase.buttons or {}) do
            if button.callback and _G[button.callback] then
                ENGINE.handlers[button.callback] = _G[button.callback]
            end
        end
    end
end
-- ============================================================
-- engine_reset
-- ============================================================
function engine_reset()

    ENGINE = ENGINE or {}

    ENGINE.phase = nil
    ENGINE.phases = nil
    ENGINE.turn = nil

    -- NON azzerare handlers/conditions qui
    ENGINE.handlers = ENGINE.handlers or {}
    ENGINE.conditions = ENGINE.conditions or {}

    TURN = nil
    DICE_CONTEST = nil
    DEFAULT = nil
end
end)
__bundle_register("engine.dispatcher", function(require, _LOADED, __bundle_register, __bundle_modules)
ENGINE = ENGINE or {}
ENGINE.handlers   = ENGINE.handlers   or {}
ENGINE.conditions = ENGINE.conditions or {}

-- ============================================================
-- FUNZIONE: registerHandler()
-- ============================================================
function registerHandler(name, func)
    ENGINE = ENGINE or {}
    ENGINE.handlers = ENGINE.handlers or {}
    ENGINE.handlers[name] = func
end
-- ============================================================
-- FUNZIONE: callHandler()
-- ============================================================
function callHandler(name, ...)

    ENGINE = ENGINE or {}
    ENGINE.handlers = ENGINE.handlers or {}

    if ENGINE.handlers[name] then
        if DEBUG and name ~= "onSave" then print(name) end
        return ENGINE.handlers[name](...)
    end

    print("Handler non registrato: " .. tostring(name))
    return true
end
-- ============================================================
-- FUNZIONE: registerCondition()
-- ============================================================
function registerCondition(name, fn)
    ENGINE = ENGINE or {}
    ENGINE.conditions = ENGINE.conditions or {}
    ENGINE.conditions[name] = fn
end
-- ============================================================
-- FUNZIONE: callCondition()
-- ============================================================
function callCondition(name, ...)
    ENGINE = ENGINE or {}
    ENGINE.conditions = ENGINE.conditions or {}

    if ENGINE.conditions[name] then
        return ENGINE.conditions[name](...)
    end

    print("Condition non registrata: " .. tostring(name))
    return false
end
-- ============================================================
-- FUNZIONE: registerRenderer()
-- NUOVO: permette ai ruleset di registrare layout UI custom
--        senza modificare engine/renderers.ttslua.
--        Uso nel loader del ruleset:
--
--          registerRenderer("mioLayout", function(phase)
--              UI.setAttribute("panelBtnUp", "active", "true")
--              ...
--          end)
--
--        Poi nelle fasi JSON:
--          "render": "mioLayout"
--
--        Se il nome collide con un renderer built-in,
--        il renderer del ruleset ha la precedenza.
-- ============================================================
function registerRenderer(name, fn)
    RENDERERS = RENDERERS or {}
    RENDERERS[name] = fn
end

end)
__bundle_register("common.utils", function(require, _LOADED, __bundle_register, __bundle_modules)
-- ============================================================
-- FUNZIONE: engine_handleChat()
-- ============================================================
    function engine_handleChat(message, player)

        if message == "!restart" then restart() return false end
        if message == "!linee" then lionheart_shootResetLines() return false end
        if message == "!clear" then clear() return false end
        if message == "!shoot"  then lionheart_shootConfirm(player) return false end
        if message == "!cancel" then lionheart_shootCancel(player)  return false end
        if message == "!test" then lionheart_testWoundButtons(player, nil, nil, nil) return false end
        if message == "!melee" then lionheart_findContacts() end   
        if message == "!join" then callHandler("lionheart_debugAttachments",player) end   
        if message == "!jjoin" then callHandler("lionheart_debugAttachmentsJson",player) end   

        return false
    end
-- ============================================================
-- FUNZIONE: error()
-- ============================================================
    function error(warning) 
        return fadeOut(warning, nil)
    end
-- ============================================================
-- FUNZIONE: fadeOut()
-- ============================================================
    function fadeOut(warning, player)

        local alpha = 1

        if player then
            UI.setAttribute("textWarning", "visibility", player.color)
        end

        UI.setAttribute("textWarning", "active", "true")
        UI.setAttribute("textWarning", "text", warning)

        local function step()
            alpha = alpha - 0.05
            if alpha <= 0 then
                UI.setAttribute("textWarning", "active", "false")
                return
            end
        
            UI.setAttribute("textWarning", "color", "rgba(255,215,0," .. alpha .. ")")
            Wait.time(step, 0.2)
        end

        step()
    end
-- ============================================================
-- FUNZIONE: warningToColor()
-- ============================================================
function warningToColor(warning, color, player)
    
    if player then
        UI.setAttribute("playerGameMessage", "Color", "Orange")
        UI.setAttribute("playerGameMessage", "text", warning)
        UI.setAttribute("playerGameMessage", "active", "true")
        UI.setAttribute("playerGameMessage", "visibility", player.color)
    end

    Wait.time(function()
        UI.setAttribute("playerGameMessage", "active", "false")
    end, 5)
    
end
-- ============================================================
-- FUNZIONE: clear()
-- ============================================================
function clear() 
    for i=0,250 do 
        printToAll("") 
    end 
end
-- ============================================================
-- FUNZIONE: getVersion()
-- ============================================================
    function getVersion()
        return VERSION
    end   
-- ============================================================
-- FUNZIONE: dice_roll()
-- ============================================================
    function dice_roll()
        return math.random(1,6)
    end
end)
