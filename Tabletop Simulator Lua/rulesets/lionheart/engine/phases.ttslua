-- ============================================================
-- FUNZIONE: initPhases()
-- ============================================================
function initPhases()

    if DEBUG then print("lionheart_initPhases") end

    linee_rettangolo = true
    linee_deploy     = false

    local phases_json = [[
    {
        "SITTING": {
            "title": "PHASE: SITTING",
            "desc": "Both players select an Army",
            "before": "before_sitting",
