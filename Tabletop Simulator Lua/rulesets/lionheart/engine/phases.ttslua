            "desc": "Roll a dice to see how many terrain elements have to place in your half of the table",
            "before": "before_field_done",
            "after": "after_field_done",
            "allowedActions": ["ARMY1_CLICK", "ARMY2_CLICK"],
            "render": "fieldConfirm",
            "enforceOwnership": true,
            "inputMode": "OWNER",
            "buttons": {
                "BTN_ARMY1": {
                    "action": "ARMY1_CLICK",
                    "label": "Im done",
                    "textColor": "White",
                     "color": "Red",
                    "callback": "field_btn_army1"
                },
                "BTN_ARMY2": {
                    "action": "ARMY2_CLICK",
                    "label": "Im done",
                    "textColor": "White",
                    "color": "Green",
