                }
            },
            "transitions": [
                {
                    "to": "MORALE",
                    "conditions": ["both_players_selected", "confirm_ready"]
                }
            ]
        },
        "MORALE": {
            "title": "PHASE: MORALE",
            "desc": "Test morale",
            "before": "before_morale",
            "after": "after_morale",            
            "allowedActions": ["CONFIRM"],
            "render": "1BtnClick",
            "enforceOwnership": true,
            "inputMode": "FREE",
            "turnStart": true,
            "buttons": {
                "BTN_SINGLE": {
                    "action": "CONFIRM",
                    "label": "Next Turn",
                    "textColor": "Black",
                    "color": "Grey",
                    "callback": "morale_btn_single"
                }
            },
            "transitions": [
                {
                    "to": "INITIATIVE_ROLL",
                    "conditions": ["confirm_immediate"]
                }
            ]
        }
    }
    ]]

    local decoded = JSON.decode(phases_json)
    if not decoded then
        print("JSON decode FALLITO")
        return
    end

    local phasesData = decoded[1] or decoded
    
    if not ENGINE then
        ENGINE = {
            phase = "SITTING",
            turn = 1,
            phases = phasesData
        }
    else
        ENGINE.phases = phasesData
    
        if not ENGINE.phase then
            ENGINE.phase = "SITTING"
        end
    
        if not ENGINE.turn then
            ENGINE.turn = 1
        end
    end

    if not TURN then
        TURN = {
            phase = ENGINE.phase,
            activeArmy = nil,
            firstArmy = nil,
            completed = {
                Army1 = false,
                Army2 = false
            }
        }
    end
end