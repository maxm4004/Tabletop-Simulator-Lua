            "allowedActions": ["ARMY1_CLICK", "ARMY2_CLICK"],
            "render": "2BtnClick",
            "enforceOwnership": false,
            "inputMode": "FREE",
            "buttons": {
                "BTN_ARMY1": {
                    "action": "ARMY1_CLICK",
                    "label": "Select Red",
                    "textColor": "White",
                     "color": "Red",
                    "callback": "sitting_btn_all"
                },
                "BTN_ARMY2": {
                    "action": "ARMY2_CLICK",
                    "label": "Select Green",
                    "textColor": "White",
                    "color": "Green",
                    "callback": "sitting_btn_all"
                }
            },
            "transitions": [
                {
                    "to": "FIELD",
