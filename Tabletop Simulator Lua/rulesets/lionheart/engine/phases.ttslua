            },
            "transitions": [
                {
                    "to": "SHOOT",
                    "conditions": ["both_players_selected", "confirm_ready"]
                }
            ]
        },
        "SHOOT": {
            "title": "PHASE: FIRE",
            "desc": "Open fire on targets",
            "before": "before_shoot",
            "after": "after_shoot",
            "allowedActions": ["ARMY1_CLICK", "ARMY2_CLICK", "CONFIRM"],
            "render": "3BtnClick",
            "enforceOwnership": true,
            "inputMode": "INITIATIVE",
            "buttons": {
                "BTN_ARMY1": {
                    "action": "ARMY1_CLICK",
                    "label": "Army 1 Done",
