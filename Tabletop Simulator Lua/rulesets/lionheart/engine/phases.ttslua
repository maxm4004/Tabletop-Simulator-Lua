        "ATTACK": {
            "title": "PHASE: ATTACK",
            "desc": "Resolve combat",
            "before": "before_attack",
            "after": "after_attack",            
            "allowedActions": ["ARMY1_CLICK", "ARMY2_CLICK", "CONFIRM"],
            "render": "3BtnClick",
            "enforceOwnership": true,
            "inputMode": "INITIATIVE",
            "buttons": {
                "BTN_ARMY1": {
                    "action": "ARMY1_CLICK",
                    "label": "Army 1 Done",
                    "textColor": "White",
                    "color": "Red",
