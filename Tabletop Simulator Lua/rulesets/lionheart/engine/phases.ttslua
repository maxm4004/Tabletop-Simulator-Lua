        "INITIATIVE_ROLL": {
            "title": "PHASE: INITIATIVE ROLL",
            "desc": "Roll dice",
            "before": "before_initiative_roll",
            "after": "after_initiative_roll",
            "allowedActions": ["ARMY1_CLICK", "ARMY2_CLICK"],
            "render": "2BtnClickAndRoll",
            "enforceOwnership": true,
            "inputMode": "OWNER",
            "buttons": {
              "BTN_ARMY1": {
                "action": "ARMY1_CLICK",
                "label": "Roll Army 1",
                "textColor": "White",
