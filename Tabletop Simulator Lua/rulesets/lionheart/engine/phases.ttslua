                }
            },
            "transitions": [
                {
                    "to": "DEPLOY_SPAWN",
                    "conditions": ["both_players_selected"]
                }
            ]
        },
        "DEPLOY_SPAWN": {
            "title": "PHASE: DEPLOY — Spawn",
