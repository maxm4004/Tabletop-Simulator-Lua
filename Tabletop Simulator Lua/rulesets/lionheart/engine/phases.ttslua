            }]
        },
        "MOVE": {
            "title": "PHASE: MOVE",
            "desc": "Move your army",
            "before": "before_move",
            "after": "after_move",
            "allowedActions": ["ARMY1_CLICK", "ARMY2_CLICK", "CONFIRM"],
            "render": "3BtnClick",
            "enforceOwnership": true,
            "inputMode": "INITIATIVE",
            "buttons": {
                "BTN_ARMY1": {
                    "action": "ARMY1_CLICK",
                    "label": "Army 1 Done",
                    "textColor": "White",
                    "color": "Red",
