-- ============================================================
-- FUNZIONE: getRulesetUiXml()
-- ============================================================
function getRulesetUiXml()

    -- Genera 2 popup identici con id diversi
    local popups = ""
    local offsets = { "0 -150", "0 -150" }  -- stessa posizione, visibilità gestita da visibility

    for slot = 1, 2 do
        local p  = "unit_popup_" .. slot
