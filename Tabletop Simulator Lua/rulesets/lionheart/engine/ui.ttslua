        <Text id="%s_sho_sk"  text="" fontSize="11" fontStyle="Bold" color="#FFFFFFFF" alignment="MiddleCenter" position="-40 -112 0"  width="55" height="18"/>
        <Text id="%s_sho_ac"  text="" fontSize="11" fontStyle="Bold" color="#FFFFFFFF" alignment="MiddleCenter" position="20 -112 0"   width="55" height="18"/>
