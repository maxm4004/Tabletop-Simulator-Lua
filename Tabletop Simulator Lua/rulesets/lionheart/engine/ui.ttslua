           color="rgba(0,0,0,0.5)"
           offsetXY="%s"
           active="false">

        <Button text="X"
                fontSize="11" fontStyle="Bold"
                color="#8B1A1AFF" textColor="White"
                width="26" height="26"
                position="185 215 0"
                onClick="onUnitPopupClose"/>

        <Image id="%s_icon"
               image="ai"
               width="120" height="130"
               position="-145 155 0"
               preserveAspect="true"
               outline="#000000" outlineSize="2"
               />

        <Text id="%s_title"
              text="" fontSize="16" fontStyle="Bold"
              color="#F0C040FF" alignment="UpperLeft"
              position="50 205 0" width="220" height="30"
              outline="#000000" outlineSize="1"/>

