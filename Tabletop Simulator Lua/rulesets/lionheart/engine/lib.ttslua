end
-- ============================================================
-- FUNZIONE: prettyPrintTable()
-- ============================================================
function prettyPrintTable(t, indent)
    indent = indent or 0

    if type(t) ~= "table" then
        print(tostring(t))
        return
    end

    for k, v in pairs(t) do
        if type(v) == "table" then
            print(string.rep("  ", indent) .. k .. ":")
            prettyPrintTable(v, indent + 1)
        else
            print(string.rep("  ", indent) .. k .. ": " .. tostring(v))
        end
    end
end
-- ============================================================
-- FUNZIONE: initUI()
-- ============================================================
function initUI()
    callHandler("buildUI")
end
-- ============================================================
-- FUNZIONE: rulesetInit()
-- ============================================================
function rulesetInit(save_state)
    
    lionheart_loadButtonBar(function(ok)
        -- slots popolati, ora buildUI genera XML con label già dentro
        callHandler("initPhases")
        callHandler("autoRegisterFromPhases")
        callHandler("registerDefaultConditions")

        if save_state and save_state ~= "" then
            callHandler("restoreState", save_state)
        end

        engine_init()  -- chiama buildUI che usa ENGINE_BUTTONBAR.slots già pronti

        if save_state and save_state ~= "" then
            Wait.time(function()
                callHandler("afterRestoreState", save_state)
            end, 1)
        end
    end)
end
-- ============================================================
-- FUNZIONE: aggiornaTintaBase
-- ============================================================
VISUALIZZAZIONE_FERITE = "tint"  -- o "highlight"

function aggiornaTintaBase(obj, wounds, fpb)
    if wounds < 1 then
        if VISUALIZZAZIONE_FERITE == "highlight" then obj.highlightOff() else obj.setColorTint({r=1,g=1,b=1}) end
        aggiornaTagInjured(obj, 0)
        return
    end
    local colore
    if wounds == 1     then colore = {r=1,   g=0.75, b=0.39}
    elseif wounds == 2 then colore = {r=1,   g=0.55, b=0}
    else                    colore = {r=0.71,g=0.33, b=0}
    end
    if VISUALIZZAZIONE_FERITE == "highlight" then obj.highlightOn(colore) else obj.setColorTint(colore) end
    aggiornaTagInjured(obj, wounds)
    obj.setDescription("Wounds: " .. wounds .. "/" .. fpb)
end
-- ============================================================
-- FUNZIONE: aggiornaTagInjured
-- ============================================================
function aggiornaTagInjured(obj, wounds)
    obj.removeTag("injured1")
    obj.removeTag("injured2")
    obj.removeTag("injured3")
    if wounds == 1     then obj.addTag("injured1")
    elseif wounds == 2 then obj.addTag("injured2")
    elseif wounds >= 3 then obj.addTag("injured3") end
end


-- ============================================================
-- FUNZIONE: lionheart_getSelectedObjects()
-- Utility generica — recupera oggetti selezionati dal player
-- ============================================================
function lionheart_getSelectedObjects(player)
    if player then
        local selected = Player[player.color].getSelectedObjects()
        if selected and #selected > 0 then return selected end
        return {}
    end
    for _, p in ipairs(getSeatedPlayers()) do
        local selected = Player[p.color].getSelectedObjects()
        if selected and #selected > 0 then return selected end
    end
    return {}
end

-- ============================================================
-- FUNZIONE: lionheart_applyFormation()
-- ============================================================
LIONHEART_FORMATION = LIONHEART_FORMATION or {
    horizontalSpacing = 3.18,
    verticalSpacing   = 2.42
}

function lionheart_lineLeft(player, value, id, buttonConfig)  return lionheart_applyFormation("lineLeft",  player) end
function lionheart_lineRight(player, value, id, buttonConfig) return lionheart_applyFormation("lineRight", player) end
function lionheart_columnUp(player, value, id, buttonConfig)  return lionheart_applyFormation("columnUp",  player) end
function lionheart_columnDown(player, value, id, buttonConfig) return lionheart_applyFormation("columnDown", player) end

function lionheart_applyFormation(mode, player)
    local selected = lionheart_getSelectedObjects(player)
    if selected == nil or #selected < 2 then
        printToAll("[FORMAZIONE] Seleziona almeno 2 basi", {r=1,g=0.6,b=0})
        return false
    end
    local leader  = selected[1]
    local right   = leader.getTransformRight()
    local forward = leader.getTransformForward()
    for i = 2, #selected do
        local obj   = selected[i]
        local index = i - 1
        local pos   = nil
        if mode == "lineLeft"   then pos = leader.getPosition() - right   * (LIONHEART_FORMATION.horizontalSpacing * index)
        elseif mode == "lineRight"  then pos = leader.getPosition() + right   * (LIONHEART_FORMATION.horizontalSpacing * index)
        elseif mode == "columnUp"   then pos = leader.getPosition() + forward * (LIONHEART_FORMATION.verticalSpacing   * index)
        elseif mode == "columnDown" then pos = leader.getPosition() - forward * (LIONHEART_FORMATION.verticalSpacing   * index)
        end
        if pos then
            obj.setPosition(pos)
            obj.setRotation(leader.getRotation())
        end
    end
    return true
end

-- ============================================================
-- FUNZIONE: lionheart_infoUnita()
-- ============================================================
function lionheart_infoUnita(player, value, id, buttonConfig)
    local selected = lionheart_getSelectedObjects(player)
    if not selected or #selected < 1 then
        printToColor("[INFO] Select a unit", player.color, {r=1,g=0.6,b=0})
        return false
    end
    local obj        = selected[1]
    local playerSlot = getArmyByColor(player)
    if playerSlot == nil then return false end
    if not obj.hasTag("Army" .. tostring(playerSlot)) then
        printToColor("[INFO] Not your unit", player.color, {r=1,g=0.3,b=0.3})
        return false
    end
    mostraPopupUnita(obj, player)
    return true
end
