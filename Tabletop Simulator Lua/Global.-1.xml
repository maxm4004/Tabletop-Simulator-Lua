<!-- LIONHEART BOT - Global UI -->

<Panel id="panelTop"
       rectAlignment="MiddleCenter"
       width="420"
       height="150"
       color="rgba(0,0,0,0.65)"
       offsetXY="0 420">

    <VerticalLayout spacing="6" padding="10 10 10 10">
    <HorizontalLayout spacing="6" childAlignment="MiddleCenter">
                <Text id="version" text="version" fontSize="14" fontStyle="Bold" color="Yellow" alignment="MiddleCenter"/>
    </HorizontalLayout>
        <Text id="textFase"
              text="FASE"
              fontSize="18"
              fontStyle="Bold"
              color="White"
              alignment="MiddleCenter"/>
        <HorizontalLayout spacing="6" childAlignment="MiddleCenter">
        <Text id="textTurn"
              text="TURN"
              fontSize="18"
              fontStyle="Bold"
              color="White"
              alignment="MiddleCenter"/>              
        </HorizontalLayout>
        <HorizontalLayout spacing="6" childAlignment="MiddleCenter">
        <Text id="army1"
              text="Army 1"
              fontSize="14"
              color="Grey"
              alignment="MiddleCenter"/>

        <Text id="army2"
              text="Army 2"
              fontSize="14"
              color="Grey"
              alignment="MiddleCenter"/>
        </HorizontalLayout>

        <Text id="textDesc"
              text="Descrizione"
              fontSize="13"
              color="rgba(0.8,0.8,0.8,1)"
              alignment="MiddleCenter"/>
    </VerticalLayout>
</Panel> 

<Panel id="panelBtnUp"
       rectAlignment="MiddleCenter"
       width="420"
       height="50"
       color="rgba(0,0,0,0.65)"
       offsetXY="0 318">
        <!-- BOTTONI -->
    <VerticalLayout spacing="6" padding="10 10 10 10">
        <HorizontalLayout>
            <Row>      
                <Button id="BTN_ARMY1"
                    text="BTN_ARMY1"
                    width="180"
                    fontSize="14"
                    color="rgba(0.7,0.15,0.15,1)"
                    textColor="White"
                    outline="#000000"
                    outlineSize="2"
                    onClick="onBtnArmy1"/>    
            </Row>
            <Row>              
                <Button id="BTN_ARMY2"
                    text="BTN_ARMY2"
                    width="180"
                    fontSize="14"
                    color="rgba(0.15,0.6,0.15,1)"
                    textColor="White"
                    outline="#000000"
                    outlineSize="2"
                    onClick="onBtnArmy2"/>
            </Row>
        </HorizontalLayout>  
    </VerticalLayout>
</Panel>
<Panel id="panelBtnDown"
       rectAlignment="MiddleCenter"
       width="420"
       height="50"
       color="rgba(0,0,0,0.65)"
       offsetXY="0 266">
        <!-- BOTTONI -->
    <VerticalLayout spacing="6" padding="10 10 10 10">
        <HorizontalLayout childAlignment="MiddleCenter">
           <Row>
                <Button id="BTN_SINGLE"
                    text="BTN_SINGLE"
                    width="380"  
                    fontSize="14"
                    color="Grey"
                    textColor="Black"
                    outline="#000000"
                    outlineSize="2"
                    onClick="onBtnScelta"/> 
           </Row>
        </HorizontalLayout>
    </VerticalLayout>
</Panel>            
<Panel id="logo_panel"
       rectAlignment="UpperCenter"
       width="600"
       height="300"
       offsetXY="-600 0">

    <Image image="https://raw.githubusercontent.com/maxm4004/Tabletop-Simulator-Lua/refs/heads/main/logo/logo.png"
           preserveAspect="1"/>
</Panel>

<Panel id="warning" rectAlignment="LowerCenter"
       width="600"
       height="30"
       color="rgba(0,0,0,0.0)"
       offsetXY="0 700">
        <Text id="textWarning"
              text=""
              fontSize="26"
              fontStyle="Bold"
              color="rgba(212,175,55,0.9)" 
              outline="#000000" 
              outlineSize="2"
              alignment="MiddleCenter"/>
</Panel>

<Panel rectAlignment="LowerCenter"
       width="600"
       height="60"
       color="rgba(0,0,0,0.85)"
       offsetXY="0 0">

    <HorizontalLayout spacing="4" 
                      childAlignment="MiddleCenter"
                      padding="8 8 8 8">
 
        <Button text="Restart" fontSize="13" fontStyle="Bold"
                color="rgba(0.15,0.4,0.8,1)" textColor="White"
                width="130" height="50" onClick="restart"/>

        <Button text="Clear" fontSize="13" fontStyle="Bold"
                color="rgba(0.15,0.4,0.8,1)" textColor="White"
                width="130" height="50" onClick="clear"/>

        <Button text="Save" fontSize="13" fontStyle="Bold"
                color="rgba(0.15,0.4,0.8,1)" textColor="White"
                width="130" height="50"/>

        <Button text="Load" fontSize="13" fontStyle="Bold"
                color="rgba(0.15,0.4,0.8,1)" textColor="White"
                width="130" height="50"/>
  
    </HorizontalLayout>
</Panel>